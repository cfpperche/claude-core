    <script>
      const printBtn = document.getElementById("mp-print");
      if (printBtn) printBtn.addEventListener("click", () => window.print());

      const filters = document.querySelectorAll<HTMLButtonElement>(".mp-filter");
      const cards = document.querySelectorAll<HTMLElement>(".mp-card");
      filters.forEach((btn) => {
        btn.addEventListener("click", () => {
          const cat = btn.dataset.cat || "all";
          filters.forEach((b) => b.setAttribute("aria-pressed", b === btn ? "true" : "false"));
          cards.forEach((c) => {
            const show = cat === "all" || c.dataset.cat === cat;
            c.style.display = show ? "" : "none";
          });
        });
      });
    </script>

