---
import "../../styles/global.css";
import { REPO_URL } from "../../i18n/locales";
import ResourcesMenu from "../../components/ResourcesMenu.astro";
import LanguageSwitcher from "../../components/LanguageSwitcher.astro";

const base = import.meta.env.BASE_URL.replace(/\/$/, "");
const siteUrl = "https://cfpperche.github.io";
const CC_VERSION = "2.1.143";
const pageTitle = `Claude Code · Plugin Marketplace · v${CC_VERSION}`;
const pageDesc = `The official Anthropic plugin marketplace for Claude Code v${CC_VERSION}: claude-code-setup as the canonical entry point, /plugin UX, 14 curated plugins across 6 categories, third-party marketplaces, security model.`;

type Cat =
  | "bootstrap"
  | "integration"
  | "workflow"
  | "lsp"
  | "output"
  | "third-party";

const categories: Record<Cat, { label: string; color: string }> = {
  bootstrap:     { label: "bootstrap",        color: "orange"   },
  integration:   { label: "external integrations", color: "magenta" },
  workflow:      { label: "development workflows", color: "cyan" },
  lsp:           { label: "code intelligence (LSP)", color: "green" },
  output:        { label: "output styles",    color: "yellow"   },
  "third-party": { label: "third-party",      color: "violet"   },
};

const plugins: {
  n: number;
  slug: string;
  cat: Cat;
  install: string;
  title: string;
  oneLine: string;
}[] = [
  { n: 1,  slug: "claude-code-setup", cat: "bootstrap",   install: "claude-code-setup@claude-plugins-official", title: "claude-code-setup",   oneLine: "Read-only analyzer that scans your codebase and recommends the top 1-2 automations per category (MCP / Skills / Hooks / Subagents / Slash commands)." },
  { n: 2,  slug: "claude-md-management", cat: "bootstrap", install: "claude-md-management@claude-plugins-official", title: "claude-md-management", oneLine: "Maintain and improve CLAUDE.md files — the project-orientation file every Claude Code session reads first." },
  { n: 3,  slug: "github",            cat: "integration", install: "github@claude-plugins-official",            title: "github",              oneLine: "Official GitHub MCP server — repos, issues, PRs, releases, code search, file edits via gh-API auth." },
  { n: 4,  slug: "gitlab",            cat: "integration", install: "gitlab@claude-plugins-official",            title: "gitlab",              oneLine: "GitLab DevOps integration — merge requests, pipelines, CI variables, project search." },
  { n: 5,  slug: "atlassian",         cat: "integration", install: "atlassian@claude-plugins-official",         title: "atlassian",           oneLine: "Jira + Confluence — read tickets, comment, transition status, search docs." },
  { n: 6,  slug: "context7",          cat: "integration", install: "context7@claude-plugins-official",          title: "context7",            oneLine: "Upstash docs lookup MCP — fetches up-to-date library documentation by name instead of hallucinated APIs." },
  { n: 7,  slug: "commit-commands",   cat: "workflow",    install: "commit-commands@claude-plugins-official",   title: "commit-commands",     oneLine: "Slash-commands for the git commit + push + PR flow — drafts the message, stages, commits, pushes." },
  { n: 8,  slug: "code-review",       cat: "workflow",    install: "code-review@claude-plugins-official",       title: "code-review",         oneLine: "Specialized agent that reviews a PR or branch — security, performance, accessibility, naming sub-agents in one dispatch." },
  { n: 9,  slug: "frontend-design",   cat: "workflow",    install: "frontend-design@claude-plugins-official",   title: "frontend-design",     oneLine: "Skill for distinctive, production-grade frontend UI — moodboarding, design tokens, component composition." },
  { n: 10, slug: "typescript-lsp",    cat: "lsp",         install: "typescript-lsp@claude-plugins-official",    title: "typescript-lsp",      oneLine: "TypeScript language server — automatic diagnostics on every edit, jump-to-def, find-refs, hover types." },
  { n: 11, slug: "pyright-lsp",       cat: "lsp",         install: "pyright-lsp@claude-plugins-official",       title: "pyright-lsp",         oneLine: "Pyright (Microsoft) language server — Python type checking + diagnostics in the same turn as the edit." },
  { n: 12, slug: "rust-analyzer-lsp", cat: "lsp",         install: "rust-analyzer-lsp@claude-plugins-official", title: "rust-analyzer-lsp",   oneLine: "rust-analyzer language server — Rust type errors, borrow checker, trait resolution surfaced inline." },
  { n: 13, slug: "explanatory-output-style", cat: "output", install: "explanatory-output-style@claude-plugins-official", title: "explanatory-output-style", oneLine: "Output style that prepends an educational note about WHY a given implementation choice was made — useful in pairing/onboarding." },
  { n: 14, slug: "claude-code-plugins-demo", cat: "third-party", install: "<plugin>@anthropics-claude-code", title: "claude-code (demo marketplace)", oneLine: "Anthropic's reference plugins, not preinstalled — adds via /plugin marketplace add anthropics/claude-code. Useful as templates when authoring your own." },
];
---

<!doctype html>
<html lang="en" data-theme="poster">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{pageTitle}</title>
    <meta name="description" content={pageDesc} />
    <meta property="og:title" content={pageTitle} />
    <meta property="og:description" content={pageDesc} />
    <meta property="og:type" content="article" />
    <meta property="og:url" content={`${siteUrl}${base}/marketplace/plugins/`} />
    <meta name="twitter:card" content="summary_large_image" />
    <link rel="icon" type="image/svg+xml" href={`${base}/favicon.svg`} />
  </head>
  <body class="mp-body">

    <div class="mp-top">
      <a href={`${base}/`} class="mp-back">← claude-core</a>
      <ResourcesMenu current="marketplace" locale="en" />
      <div class="mp-top-tools">
        <LanguageSwitcher
          enHref={`${base}/marketplace/plugins/`}
          ptHref={`${base}/marketplace/pt/plugins/`}
          esHref={`${base}/marketplace/es/plugins/`}
          current="en"
        />
        <button id="mp-print" type="button" class="mp-tool-btn" title="Print as PDF (uses browser PDF)">
          <span aria-hidden="true">↓</span> PDF
        </button>
      </div>
    </div>

    <main class="mp-page">

      <header class="mp-banner">
        <div class="mp-strip">
          <span class="mp-tag">▮ CLAUDE-CORE · ACADEMY</span>
          <span class="mp-tag">CLAUDE CODE v{CC_VERSION}</span>
          <span class="mp-tag">14 PLUGINS · 6 CATEGORIES ▮</span>
        </div>
        <h1 class="mp-title">
          <span class="mp-title-line">PLUGIN</span>
          <span class="mp-title-line mp-title-accent">MARKETPLACE</span>
        </h1>
        <p class="mp-sub">
          Most Claude Code users still run vanilla. The real power lives in the official plugin marketplace — preinstalled, /plugin away, and shaped around the same primitives this site teaches (hooks, skills, MCP, subagents). This page covers the discovery UX, the canonical entry point (<code>claude-code-setup</code>), 14 hand-picked plugins across 6 categories, and the security model you should hold before installing anything.
        </p>
      </header>

      <section class="mp-intro">
        <h2 class="mp-intro-h">What a marketplace is, in 30 seconds</h2>
        <p>
          A <b>marketplace</b> is a catalog of <b>plugins</b>. A <b>plugin</b> is a bundle of <code>skills</code> + <code>agents</code> + <code>hooks</code> + <code>MCP servers</code> + <code>slash commands</code> + <code>LSP integrations</code> — same primitives you'd write by hand, packaged for distribution. The official Anthropic marketplace (<code>claude-plugins-official</code>) is auto-registered when you start Claude Code. Other marketplaces — including Anthropic's own demo, your team's private one, or any third-party — you add explicitly.
        </p>
        <h2 class="mp-intro-h">The two-step model</h2>
        <ol class="mp-intro-ol">
          <li><b>Add the marketplace</b> — registers the catalog. No plugins installed yet.</li>
          <li><b>Install individual plugins</b> — browse, pick, install at one of three scopes.</li>
        </ol>
        <p class="mp-intro-note">App store metaphor: adding the store gives you the browse surface; install is per-app, per-scope. The whole flow lives behind one slash command — <code>/plugin</code>.</p>
      </section>

      <!-- ===== §1 the /plugin UX ===== -->

      <section class="mp-mod mp-fam-orange" id="m1">
        <header class="mp-mod-head">
          <span class="mp-mod-n">§1</span>
          <h2 class="mp-mod-h">The /plugin command — four tabs</h2>
        </header>
        <p class="mp-mod-when"><b>What</b> — <code>/plugin</code> opens a four-tab manager. Tab through with <kbd>Tab</kbd> (or <kbd>Shift+Tab</kbd> backward).</p>

        <ul class="mp-mod-list">
          <li><b>Discover</b> — browse plugins from every registered marketplace. Filter by name or description. Press <kbd>Enter</kbd> on a plugin to see details and install.</li>
          <li><b>Installed</b> — list of installed plugins, grouped by scope, sorted with load-errors and unresolved-dependencies first. Press <kbd>f</kbd> to favorite; type to filter; <kbd>Enter</kbd> for detail view (enable / disable / uninstall).</li>
          <li><b>Marketplaces</b> — manage which catalogs are registered. Add new ones, refresh, remove, toggle auto-update.</li>
          <li><b>Errors</b> — any plugin that failed to load (often: missing LSP binary in <code>$PATH</code>).</li>
        </ul>

        <p class="mp-mini-h">▸ CLI shortcuts (skip the UI)</p>
        <pre class="mp-code"><code>{`# Install (defaults to User scope)
/plugin install <plugin>@<marketplace>

# Manage
/plugin disable <plugin>@<marketplace>
/plugin enable  <plugin>@<marketplace>
/plugin uninstall <plugin>@<marketplace>

# Pick up changes mid-session, no restart
/reload-plugins

# Shortcuts: /plugin market === /plugin marketplace; rm === remove`}</code></pre>

        <p class="mp-gotcha"><b>Gotcha</b> — <code>/reload-plugins</code> is the most-forgotten command. If you install a plugin and its skills don't show up, you almost always just needed to reload. After reload, the output shows counts for plugins, skills, agents, hooks, MCP servers, and LSP servers — confirm the new plugin's contributions appear.</p>
      </section>

      <!-- ===== §2 install scopes ===== -->

      <section class="mp-mod mp-fam-magenta" id="m2">
        <header class="mp-mod-head">
          <span class="mp-mod-n">§2</span>
          <h2 class="mp-mod-h">Three install scopes — pick deliberately</h2>
        </header>

        <table class="mp-table">
          <thead><tr><th>Scope</th><th>Who</th><th>Where it lives</th><th>Use when…</th></tr></thead>
          <tbody>
            <tr>
              <td><code>user</code> <em>(default)</em></td>
              <td>You, every project</td>
              <td><code>~/.claude/settings.json</code></td>
              <td>You'd use this everywhere — <code>commit-commands</code>, <code>github</code>, an LSP for your daily language.</td>
            </tr>
            <tr>
              <td><code>project</code></td>
              <td>You + every collaborator on this repo</td>
              <td><code>.claude/settings.json</code> (git-tracked)</td>
              <td>The plugin is part of the project's contract — a code-review agent the whole team should run, a hook policy.</td>
            </tr>
            <tr>
              <td><code>local</code></td>
              <td>You, this repo only</td>
              <td><code>.claude/settings.local.json</code> (gitignored)</td>
              <td>Experimenting; not ready to bless for the team; your personal observability stack.</td>
            </tr>
            <tr>
              <td><code>managed</code></td>
              <td>Org admin pushed it</td>
              <td>Managed settings file</td>
              <td>Read-only from your side. You see it; you can't disable it.</td>
            </tr>
          </tbody>
        </table>

        <p class="mp-mini-h">▸ CLI scope flag (bypasses the picker)</p>
        <pre class="mp-code"><code>{`claude plugin install formatter@your-org --scope project
claude plugin uninstall formatter@your-org --scope project`}</code></pre>

        <p class="mp-gotcha"><b>Gotcha</b> — installing at <code>user</code> scope (the default) means the plugin is active in <i>every</i> repo you open. If the plugin adds an aggressive hook or output style, it bleeds into projects where you didn't want it. When in doubt, install at <code>local</code> first, validate, then promote.</p>
      </section>

      <!-- ===== §3 claude-code-setup ===== -->

      <section class="mp-mod mp-fam-cyan" id="m3">
        <header class="mp-mod-head">
          <span class="mp-mod-n">§3</span>
          <h2 class="mp-mod-h">The canonical entry point — <code>claude-code-setup</code></h2>
        </header>
        <p class="mp-mod-when"><b>Why</b> — staring at a marketplace of 200+ plugins isn't where you want to start. <code>claude-code-setup</code> is a single read-only skill, published by Anthropic, that scans your codebase and recommends the top 1-2 automations per category. It's the bootstrapping primitive for any existing repo adopting Claude Code.</p>

        <p class="mp-mini-h">▸ Install</p>
        <pre class="mp-code"><code>{`/plugin install claude-code-setup@claude-plugins-official
/reload-plugins`}</code></pre>

        <p class="mp-mini-h">▸ Use — any of these prompts triggers it</p>
        <pre class="mp-code"><code>{`"recommend automations for this project"
"help me set up Claude Code"
"what hooks should I use?"`}</code></pre>

        <p class="mp-mini-h">▸ What it recommends, by category</p>
        <ul class="mp-mod-list">
          <li><b>MCP Servers</b> — external integrations (e.g., <code>context7</code> for docs lookup, Playwright MCP for frontend automation).</li>
          <li><b>Skills</b> — packaged expertise (e.g., a Plan skill for spec-driven work, <code>frontend-design</code>).</li>
          <li><b>Hooks</b> — automatic actions (auto-format on edit, auto-lint, block sensitive paths).</li>
          <li><b>Subagents</b> — specialized reviewers (security, performance, accessibility).</li>
          <li><b>Slash commands</b> — quick workflows (<code>/test</code>, <code>/pr-review</code>, <code>/explain</code>).</li>
        </ul>

        <p class="mp-gotcha"><b>Safety</b> — the skill is <b>read-only</b>. It analyzes, it doesn't install. After the recommendation lands, <i>you</i> decide which plugins to install and at what scope. Treat the output as a starting point for <code>/plugin install</code>, not as ground truth — the recommendation reflects what the skill saw, not necessarily what your project needs long-term.</p>
      </section>

      <!-- ===== §4 the catalog ===== -->

      <section class="mp-mod mp-fam-green" id="m4">
        <header class="mp-mod-head">
          <span class="mp-mod-n">§4</span>
          <h2 class="mp-mod-h">14 plugins worth knowing — curated</h2>
        </header>
        <p class="mp-mod-when"><b>How to read this</b> — the marketplace ships 200+ plugins and moves fast. The 14 below were picked for breadth (one or two per category) and staying power (built or sponsored by stable upstream maintainers). For the live catalog, run <code>/plugin</code> and tab to <b>Discover</b>, or visit <a href="https://claude.com/plugins" target="_blank" rel="noopener">claude.com/plugins</a>.</p>

        <nav class="mp-filters" aria-label="Filter by category">
          <span class="mp-filter-h">▸ FILTER BY CATEGORY</span>
          <button type="button" class="mp-filter mp-filter-all" data-cat="all" aria-pressed="true">all ({plugins.length})</button>
          {Object.entries(categories).map(([key, meta]) => {
            const count = plugins.filter((p) => p.cat === key).length;
            return (
              <button type="button" class={`mp-filter mp-filter-${meta.color}`} data-cat={key} aria-pressed="false">
                {meta.label} ({count})
              </button>
            );
          })}
        </nav>

        <div class="mp-grid">
          {plugins.map((p) => {
            const meta = categories[p.cat];
            return (
              <article class={`mp-card mp-fam-${meta.color}`} data-cat={p.cat}>
                <header class="mp-card-head">
                  <span class="mp-card-n">#{p.n}</span>
                  <h3 class="mp-card-h">{p.title}</h3>
                  <span class="mp-card-cat">{meta.label}</span>
                </header>
                <p class="mp-card-desc">{p.oneLine}</p>
                <pre class="mp-card-install"><code>/plugin install {p.install}</code></pre>
              </article>
            );
          })}
        </div>

        <p class="mp-gotcha"><b>Gotcha</b> — LSP plugins require the language server <i>binary</i> to be on your <code>$PATH</code> (e.g., <code>typescript-language-server</code>, <code>pyright-langserver</code>, <code>rust-analyzer</code>). If the <code>/plugin</code> Errors tab shows <code>Executable not found in $PATH</code>, the plugin installed correctly — you just need to install its sibling binary via your package manager (<code>brew</code>, <code>npm</code>, <code>cargo</code>, system package).</p>
      </section>

      <!-- ===== §5 third-party marketplaces ===== -->

      <section class="mp-mod mp-fam-violet" id="m5">
        <header class="mp-mod-head">
          <span class="mp-mod-n">§5</span>
          <h2 class="mp-mod-h">Adding third-party marketplaces</h2>
        </header>
        <p class="mp-mod-when"><b>When</b> — your team has a private plugin catalog, you want to try a community marketplace, or you're testing a marketplace you're building. The official one ships preinstalled; everything else needs an explicit <code>add</code>.</p>

        <p class="mp-mini-h">▸ From a GitHub repo (most common)</p>
        <pre class="mp-code"><code>{`/plugin marketplace add owner/repo

# Anthropic's demo marketplace (separate from the official)
/plugin marketplace add anthropics/claude-code`}</code></pre>

        <p class="mp-mini-h">▸ From any Git host (include .git suffix)</p>
        <pre class="mp-code"><code>{`/plugin marketplace add https://gitlab.com/company/plugins.git
/plugin marketplace add git@gitlab.com:company/plugins.git

# Pin to a specific branch or tag
/plugin marketplace add https://gitlab.com/company/plugins.git#v1.0.0`}</code></pre>

        <p class="mp-mini-h">▸ From a local path or remote URL</p>
        <pre class="mp-code"><code>{`/plugin marketplace add ./my-marketplace
/plugin marketplace add ./path/to/marketplace.json
/plugin marketplace add https://example.com/marketplace.json`}</code></pre>

        <p class="mp-mini-h">▸ Manage the registered set</p>
        <pre class="mp-code"><code>{`/plugin marketplace list
/plugin marketplace update <name>
/plugin marketplace remove <name>     # uninstalls every plugin from it!`}</code></pre>

        <p class="mp-gotcha"><b>Gotcha</b> — <code>marketplace remove</code> is destructive. Removing a marketplace uninstalls every plugin you sourced from it. If you only want to stop auto-updates, disable the auto-update toggle in the Marketplaces tab instead.</p>
      </section>

      <!-- ===== §6 team marketplaces via project settings ===== -->

      <section class="mp-mod mp-fam-yellow" id="m6">
        <header class="mp-mod-head">
          <span class="mp-mod-n">§6</span>
          <h2 class="mp-mod-h">Team marketplaces — auto-prompt on repo trust</h2>
        </header>
        <p class="mp-mod-when"><b>When</b> — the team has a shared plugin catalog and you want new contributors to install it without onboarding friction. Declared in <code>.claude/settings.json</code>, prompted on first repo trust.</p>

        <p class="mp-mini-h">▸ <code>.claude/settings.json</code></p>
        <pre class="mp-code"><code>{`{
  "extraKnownMarketplaces": {
    "my-team-tools": {
      "source": {
        "source": "github",
        "repo": "your-org/claude-plugins"
      }
    }
  }
}`}</code></pre>

        <p class="mp-mod-when">When a teammate first opens the repo and trusts it, Claude Code prompts them to install the listed marketplaces and any <code>enabledPlugins</code> declared alongside. They opt in or skip; the repo doesn't enforce.</p>

        <p class="mp-gotcha"><b>Gotcha</b> — third-party and local-development marketplaces ship with <b>auto-update disabled</b> by default (only official Anthropic marketplaces auto-update). Admins can flip <code>"autoUpdate": true</code> per-entry in managed settings if the org wants forced refreshes. For most teams, manual <code>/plugin marketplace update</code> at known stable points is healthier than silent updates.</p>
      </section>

      <!-- ===== §7 security ===== -->

      <section class="mp-mod mp-fam-orange" id="m7">
        <header class="mp-mod-head">
          <span class="mp-mod-n">§7</span>
          <h2 class="mp-mod-h">The security model — earn the trust</h2>
        </header>
        <p class="mp-mod-when"><b>What's at stake</b> — plugins and marketplaces execute arbitrary code with <i>your</i> user privileges. A plugin can run shell, read your files, hit the network, modify your environment. Anthropic does not audit plugin code; the <code>claude-plugins-official</code> badge means Anthropic curates the catalog, not that the runtime is sandboxed.</p>

        <ul class="mp-mod-list">
          <li><b>Trust the source first</b> — check the plugin's repo on the homepage link. Read what hooks it installs, what MCP servers it spins up, what permissions it expects.</li>
          <li><b>Prefer narrow scope</b> — start at <code>local</code> for anything you haven't read, promote to <code>project</code> or <code>user</code> only after validating in a real session.</li>
          <li><b>Pin marketplaces you don't own</b> — for Git-based third-party marketplaces, append <code>#</code>{`<sha-or-tag>`} to lock the version instead of tracking <code>main</code>.</li>
          <li><b>Org control</b> — admins can restrict which marketplaces are addable via managed settings (<code>extraKnownMarketplaces</code> with a deny list). Worth setting up before a team grows past five people.</li>
        </ul>

        <p class="mp-mini-h">▸ The two-line audit reflex</p>
        <pre class="mp-code"><code>{`# 1. Where does the plugin live? (read this before installing)
gh repo view <owner>/<repo> --json url,description,homepageUrl

# 2. What hooks / commands / MCP does it ship? (look inside .claude-plugin/)
gh repo clone <owner>/<repo> && grep -RIn 'hook\\|command\\|mcpServers' .claude-plugin/`}</code></pre>

        <p class="mp-gotcha"><b>Gotcha</b> — official marketplaces auto-update by default. Even the official ones can ship a bad release, so if a session breaks after a startup notification ("plugins updated"), check <code>/plugin</code> → Marketplaces → toggle off auto-update for the suspect entry, then bisect. <code>FORCE_AUTOUPDATE_PLUGINS=1</code> + <code>DISABLE_AUTOUPDATER=1</code> keeps plugin updates while pinning the CLI itself — useful when you've stabilized a workflow.</p>
      </section>

      <!-- ===== §8 troubleshooting ===== -->

      <section class="mp-mod mp-fam-cyan" id="m8">
        <header class="mp-mod-head">
          <span class="mp-mod-n">§8</span>
          <h2 class="mp-mod-h">Troubleshooting — the four real failure modes</h2>
        </header>

        <ul class="mp-mod-list">
          <li><b><code>/plugin command not recognized</code></b> — Claude Code is too old. Check <code>claude --version</code>; update via <code>brew upgrade claude-code</code>, <code>npm install -g @anthropic-ai/claude-code@latest</code>, or re-run the native installer. Restart the terminal.</li>
          <li><b><code>not found in any marketplace</code></b> — the marketplace data is stale. Run <code>/plugin marketplace update claude-plugins-official</code> (or whichever one). If that fails, <code>/plugin marketplace add anthropics/claude-plugins-official</code> to re-register, then retry the install.</li>
          <li><b>Plugin skills don't appear</b> — usually a missing reload. Run <code>/reload-plugins</code>. If still absent, clear the cache: <code>rm -rf ~/.claude/plugins/cache</code>, restart, reinstall.</li>
          <li><b><code>Executable not found in $PATH</code></b> in the Errors tab — LSP plugin installed, language server binary missing. Install the binary via your package manager (per the Code intelligence table on the official docs).</li>
        </ul>
      </section>

      <!-- ===== closer ===== -->

      <section class="mp-closer">
        <h2 class="mp-closer-h">Where this slots into the rest of claude-core</h2>
        <p>
          The marketplace is the <b>discovery layer</b>. The other surfaces on this site teach the <i>primitives</i> that plugins are built from:
        </p>
        <ul class="mp-closer-ul">
          <li>The <a href={`${base}/cheatsheet/claude-core/`}>Cheatsheet</a> is the dense reference — every CLI flag and hook event the plugins use.</li>
          <li>The <a href={`${base}/masterclass/claude-code/`}>Master Class</a> walks the linear path so you have a mental model before adopting plugins.</li>
          <li>The <a href={`${base}/cookbook/hooks/`}>Hook Cookbook</a> shows what a hook actually looks like, so you can read what a plugin's hooks do (or write your own).</li>
          <li>The <a href={`${base}/masterclass/goal-command/`}>/goal Class</a> covers the worker/evaluator pattern that plugins like <code>code-review</code> instantiate.</li>
          <li>The <a href={`${base}/masterclass/routing/`}>Routing Class</a> covers extending the model layer — same architectural shape as extending the agent layer via plugins.</li>
        </ul>
        <p>
          Plugins are how the ecosystem ships expertise; primitives are how you read what they did and customize it. Both directions matter.
        </p>
      </section>

      <footer class="mp-foot">
