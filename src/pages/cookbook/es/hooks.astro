      .ck-recipe { margin-bottom: 28px; padding: 18px 22px; background: rgba(0,0,0,0.28); border-left: 3px solid var(--ck-fam, var(--p-ink-faint)); border-radius: 2px; scroll-margin-top: 20px; }
      .ck-fam-cyan    { --ck-fam: var(--p-cyan); }
      .ck-fam-magenta { --ck-fam: var(--p-magenta); }
      .ck-fam-orange  { --ck-fam: var(--p-orange); }
      .ck-fam-green   { --ck-fam: var(--p-green); }
      .ck-fam-violet  { --ck-fam: var(--p-violet); }
      .ck-fam-yellow  { --ck-fam: var(--p-yellow); }

      .ck-rec-head { display: flex; align-items: baseline; gap: 12px; margin-bottom: 10px; padding-bottom: 6px; border-bottom: 1px solid rgba(255,255,255,0.08); flex-wrap: wrap; }
      .ck-rec-n { font-family: var(--font-mono); font-size: 18px; font-weight: 800; color: var(--ck-fam); }
      .ck-rec-h { font-family: var(--font-mono); font-size: 16px; font-weight: 700; color: var(--p-ink); margin: 0; flex: 1; line-height: 1.35; }
