const base = import.meta.env.BASE_URL.replace(/\/$/, "");
const siteUrl = "https://cfpperche.github.io";
const CC_VERSION = "2.1.143";
const CCR_VERSION = "1.0.x";
const pageTitle = `Claude Code · Routing Class · CCRouter`;
const pageDesc = `Extend Claude Code with CCRouter — the local proxy that routes requests to any model by task type. 4 modules + 8 copy-paste routing recipes.`;

const cheatsheetPath = `${base}/cheatsheet/claude-core/`;
const masterclassPath = `${base}/masterclass/claude-code/`;
const goalPath = `${base}/masterclass/goal-command/`;
const cookbookPath = `${base}/cookbook/hooks/`;

const modules = [
  { n: 1, slug: "why",      title: "Why Route?",                tag: "foundations" },
  { n: 2, slug: "arch",     title: "The Architecture",          tag: "internals"   },
  { n: 3, slug: "install",  title: "Install + First Config",    tag: "craft"       },
  { n: 4, slug: "routes",   title: "The Six Routes",            tag: "craft"       },
];

const recipes = [
  { n: 1, slug: "r-background", title: "Send background tasks to a cheap model",      need: "Cost"        },
  { n: 2, slug: "r-longctx",    title: "Route long-context to Gemini 2.5 Pro",        need: "Capability"  },
  { n: 3, slug: "r-ollama",     title: "Local-first via Ollama (offline / private)",  need: "Privacy"     },
  { n: 4, slug: "r-subagent",   title: "Sub-agents to Haiku, parent to Opus",         need: "Cost"        },
  { n: 5, slug: "r-failover",   title: "Failover chain: Anthropic → OpenRouter",      need: "Reliability" },
  { n: 6, slug: "r-budget",     title: "Daily budget cap with API_TIMEOUT_MS",        need: "Cost"        },
  { n: 7, slug: "r-perproject", title: "Per-project routing override",                need: "Scope"       },
  { n: 8, slug: "r-transformer",title: "Custom transformer — strip reasoning tokens", need: "Compat"      },
];
