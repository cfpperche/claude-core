import LanguageSwitcher from "../../../components/LanguageSwitcher.astro";

const base = import.meta.env.BASE_URL.replace(/\/$/, "");
const siteUrl = "https://cfpperche.github.io";
const CC_VERSION = "2.1.143";
const FEATURE_VERSION = "2.1.139";   // /goal landed here
const pageTitle = `Claude Code · /goal Master Class · v${CC_VERSION} (pt-BR)`;
const pageDesc = `Aprofundamento no comando /goal no Claude Code v${CC_VERSION}: anatomia de uma condição, arquitetura do evaluator, vs /loop e Stop hooks, uso headless, anti-padrões. 8 módulos.`;

const cheatsheetPath = `${base}/cheatsheet/pt/claude-core/`;
const masterclassPath = `${base}/masterclass/pt/claude-code/`;
const cookbookPath = `${base}/cookbook/pt/hooks/`;

const modules = [
  { n: 1, slug: "what",        title: "O que /goal é",                       tag: "fundamentos" },
  { n: 2, slug: "vs",          title: "/goal vs /loop vs Stop Hook vs Auto", tag: "fundamentos" },
  { n: 3, slug: "anatomy",     title: "Anatomia de uma boa condição",        tag: "prática"     },
  { n: 4, slug: "gallery",     title: "Bom vs Ruim — uma galeria",           tag: "prática"     },
  { n: 5, slug: "bounding",    title: "Pondo limites no run",                tag: "prática"     },
  { n: 6, slug: "evaluator",   title: "Como o evaluator funciona",           tag: "internos"    },
  { n: 7, slug: "headless",    title: "/goal headless",                      tag: "produção"    },
  { n: 8, slug: "antipatterns",title: "Limitações & Anti-padrões",           tag: "produção"    },
];
---

<!doctype html>
<html lang="pt-BR" data-theme="poster">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
