const base = import.meta.env.BASE_URL.replace(/\/$/, "");
const siteUrl = "https://cfpperche.github.io";
const CC_VERSION = "2.1.143";
const CCR_VERSION = "1.0.x";
const pageTitle = `Claude Code · Routing Class · CCRouter`;
const pageDesc = `Estenda o Claude Code com o CCRouter — o proxy local que roteia requests pra qualquer modelo por tipo de tarefa. 4 módulos + 8 receitas de roteamento copy-paste.`;

const cheatsheetPath = `${base}/cheatsheet/pt/claude-core/`;
const masterclassPath = `${base}/masterclass/pt/claude-code/`;
const goalPath = `${base}/masterclass/pt/goal-command/`;
const cookbookPath = `${base}/cookbook/pt/hooks/`;

const modules = [
  { n: 1, slug: "why",      title: "Por que rotear?",              tag: "fundamentos" },
  { n: 2, slug: "arch",     title: "A arquitetura",                tag: "internos"    },
  { n: 3, slug: "install",  title: "Instalação + primeira config", tag: "prática"     },
  { n: 4, slug: "routes",   title: "As seis rotas",                tag: "prática"     },
];

const recipes = [
  { n: 1, slug: "r-background", title: "Mande tarefas background pra um modelo barato",  need: "Custo"        },
  { n: 2, slug: "r-longctx",    title: "Roteia long-context pro Gemini 2.5 Pro",         need: "Capacidade"   },
  { n: 3, slug: "r-ollama",     title: "Local-first via Ollama (offline / privado)",     need: "Privacidade"  },
  { n: 4, slug: "r-subagent",   title: "Sub-agents pra Haiku, parent pra Opus",          need: "Custo"        },
  { n: 5, slug: "r-failover",   title: "Cadeia de failover: Anthropic → OpenRouter",     need: "Confiabilidade" },
  { n: 6, slug: "r-budget",     title: "Teto diário com API_TIMEOUT_MS",                 need: "Custo"        },
  { n: 7, slug: "r-perproject", title: "Override de roteamento por projeto",             need: "Escopo"       },
  { n: 8, slug: "r-transformer",title: "Transformer custom — descarta reasoning tokens", need: "Compat"       },
];
