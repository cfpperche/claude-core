const cheatsheetPath = `${base}/cheatsheet/claude-core/`;

const modules = [
  { n: 1,  slug: "mental-model",      title: "Mental Model",                tag: "foundations"  },
  { n: 2,  slug: "first-session",     title: "Your First Session",          tag: "foundations"  },
  { n: 3,  slug: "claude-md",         title: "CLAUDE.md, the manual",       tag: "foundations"  },
  { n: 4,  slug: "permissions",       title: "Permissions & Safety",        tag: "foundations"  },
  { n: 5,  slug: "mcp",               title: "The MCP Universe",            tag: "capabilities" },
  { n: 6,  slug: "skills",            title: "Skills — bottling prompts",   tag: "capabilities" },
  { n: 7,  slug: "agents",            title: "Agents — delegation",         tag: "capabilities" },
