const pageDesc = `Extiende Claude Code con CCRouter — el proxy local que enruta las peticiones a cualquier modelo por tipo de tarea. 4 módulos + 8 recetas de enrutamiento copia-pega.`;

const cheatsheetPath = `${base}/cheatsheet/es/claude-core/`;
const masterclassPath = `${base}/masterclass/es/claude-code/`;
const goalPath = `${base}/masterclass/es/goal-command/`;
const cookbookPath = `${base}/cookbook/es/hooks/`;

const modules = [
  { n: 1, slug: "why",      title: "¿Por qué enrutar?",            tag: "fundamentos" },
  { n: 2, slug: "arch",     title: "La arquitectura",              tag: "internos"    },
  { n: 3, slug: "install",  title: "Instalación + primera config", tag: "práctica"    },
  { n: 4, slug: "routes",   title: "Las seis rutas",               tag: "práctica"    },
];

const recipes = [
  { n: 1, slug: "r-background", title: "Manda tareas background a un modelo barato",        need: "Costo"          },
  { n: 2, slug: "r-longctx",    title: "Enruta long-context a Gemini 2.5 Pro",              need: "Capacidad"      },
  { n: 3, slug: "r-ollama",     title: "Local-first vía Ollama (offline / privado)",        need: "Privacidad"     },
  { n: 4, slug: "r-subagent",   title: "Sub-agents a Haiku, parent a Opus",                 need: "Costo"          },
  { n: 5, slug: "r-failover",   title: "Cadena de failover: Anthropic → OpenRouter",        need: "Confiabilidad"  },
  { n: 6, slug: "r-budget",     title: "Tope diario con API_TIMEOUT_MS",                    need: "Costo"          },
  { n: 7, slug: "r-perproject", title: "Override de enrutamiento por proyecto",             need: "Alcance"        },
  { n: 8, slug: "r-transformer",title: "Transformer custom — descarta reasoning tokens",    need: "Compat"         },
];
