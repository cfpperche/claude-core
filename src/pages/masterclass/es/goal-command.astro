const pageTitle = `Claude Code · /goal Master Class · v${CC_VERSION} (es)`;
const pageDesc = `Inmersión profunda en el comando /goal en Claude Code v${CC_VERSION}: anatomía de una condición, arquitectura del evaluator, vs /loop y Stop hooks, uso headless, anti-patrones. 8 módulos.`;

