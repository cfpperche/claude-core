      .mc-toc-tag { font-size: 9.5px; color: var(--p-ink-faint); letter-spacing: 0.06em; text-transform: uppercase; }
      .mc-toc-list a[data-tag="foundations"] .mc-toc-tag { color: var(--p-cyan); }
      .mc-toc-list a[data-tag="craft"]       .mc-toc-tag { color: var(--p-magenta); }
      .mc-toc-list a[data-tag="internals"]   .mc-toc-tag { color: var(--p-violet); }
      .mc-toc-list a[data-tag="production"]  .mc-toc-tag { color: var(--p-yellow); }

      .mc-mod { margin-bottom: 48px; scroll-margin-top: 20px; }
