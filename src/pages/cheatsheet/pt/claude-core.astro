          grid-template-areas:
            "settings" "hooks"
            "claudemd" "mcp"
            "skills" "agents"
            "tools"
            "auth"
            "cost"
            "output" "plugin"
            "workflow"
            "commands"
            "envvars";
        }
      }

      /* ENV VARS — reuse cmd-cols but in green */
      .env-cols .cmd-h {
        color: var(--p-green);
        border-bottom-color: rgba(57, 255, 20, 0.25);
      }
      .env-cols .cmd-list li code {
        color: var(--p-green);
        background: rgba(57, 255, 20, 0.06);
      }

      /* ===== RECIPES SECTION ===== */
      .recipes-section {
        margin-top: 18px;
      }

      /* ===== DIAGRAM PRIMITIVES (shared) ===== */
      .dgm-wrap {
        margin: 10px 0;
        padding: 8px;
        background: rgba(0, 0, 0, 0.25);
        border: 1px dashed rgba(255, 255, 255, 0.08);
        border-radius: 3px;
      }
      .dgm-h {
        font-family: var(--font-mono);
        font-size: 10.5px;
        letter-spacing: 0.1em;
        color: var(--c, var(--p-ink-dim));
        margin: 0 0 6px;
      }
      .dgm-svg {
        display: block;
        width: 100%;
        height: auto;
        font-family: var(--font-mono);
      }

      /* shared SVG primitives */
      .dgm-svg .dgm-box {
        fill: rgba(0, 0, 0, 0.4);
        stroke-width: 1.2;
        rx: 3;
      }
      .dgm-svg .dgm-box-green   { stroke: var(--p-green); }
      .dgm-svg .dgm-box-orange  { stroke: var(--p-orange); }
      .dgm-svg .dgm-box-red     { stroke: var(--p-red); }
      .dgm-svg .dgm-box-cyan    { stroke: var(--p-cyan); }
      .dgm-svg .dgm-box-magenta { stroke: var(--p-magenta); }
      .dgm-svg .dgm-box-yellow  { stroke: var(--p-yellow); }
      .dgm-svg .dgm-box-violet  { stroke: var(--p-violet); }
      .dgm-svg .dgm-box-pink    { stroke: var(--p-pink); }
      .dgm-svg .dgm-q {
        fill: rgba(255, 215, 0, 0.08);
        stroke: var(--p-yellow);
        stroke-width: 1.2;
        rx: 3;
      }
      .dgm-svg .dgm-arr {
        stroke: var(--p-ink-dim);
        stroke-width: 1.2;
        fill: none;
        color: var(--p-ink-dim);
      }
      .dgm-svg .dgm-arr-yes { stroke: var(--p-green); color: var(--p-green); }
      .dgm-svg .dgm-arr-no  { stroke: var(--p-red); color: var(--p-red); }
      .dgm-svg .dgm-arr-lbl {
        font-size: 10px;
        font-weight: 700;
        text-anchor: middle;
        letter-spacing: 0.04em;
      }
      .dgm-svg .dgm-arr-lbl-yes { fill: var(--p-green); }
      .dgm-svg .dgm-arr-lbl-no  { fill: var(--p-red); }
      .dgm-svg .dgm-lbl {
        font-size: 11px;
        font-weight: 600;
        text-anchor: middle;
        fill: var(--p-ink);
      }
      .dgm-svg .dgm-lbl-sm {
        font-size: 9.5px;
        text-anchor: middle;
        fill: var(--p-ink-faint);
        letter-spacing: 0.04em;
      }

      /* token-bar specific */
      .dgm-bar-seg { stroke: rgba(0, 0, 0, 0.4); stroke-width: 1; }
      .dgm-bar-seg.seg-orange  { fill: rgba(255, 153, 51, 0.7); }
      .dgm-bar-seg.seg-cyan    { fill: rgba(0, 229, 255, 0.7); }
      .dgm-bar-seg.seg-magenta { fill: rgba(255, 68, 255, 0.6); }
      .dgm-bar-seg.seg-green   { fill: rgba(57, 255, 20, 0.7); }
      .dgm-bar-lbl {
        font-size: 11px;
        font-weight: 600;
        fill: var(--p-ink);
        text-anchor: middle;
      }
      .dgm-bar-pct {
        font-size: 13px;
        font-weight: 800;
        fill: rgba(0, 0, 0, 0.85);
        text-anchor: middle;
      }

      /* ===== HUB NAV (Claude Code learning set) ===== */
      .hub {
        background: linear-gradient(135deg, rgba(255,68,255,0.05), rgba(0,229,255,0.04));
        border: 1px solid rgba(255,255,255,0.08);
        border-radius: 4px;
        padding: 18px 22px;
        margin: 0 0 28px;
      }
      .hub-head {
        display: flex;
        align-items: baseline;
        justify-content: space-between;
        gap: 14px;
        flex-wrap: wrap;
        margin-bottom: 6px;
      }
      .hub-eyebrow {
        font-family: var(--font-mono);
        font-size: 11px;
        color: var(--p-magenta);
        letter-spacing: 0.12em;
        font-weight: 700;
      }
      .hub-here {
        font-family: var(--font-mono);
        font-size: 10.5px;
        color: var(--p-green);
        letter-spacing: 0.04em;
      }
      .hub-here-tag { color: var(--p-ink-faint); }
      .hub-intro {
        color: var(--p-ink-dim);
        font-size: 13px;
        margin: 0 0 14px;
        line-height: 1.5;
      }
      .hub-grid {
        display: grid;
        grid-template-columns: repeat(3, 1fr);
        gap: 14px;
      }
      @media (max-width: 900px) {
        .hub-grid { grid-template-columns: 1fr; }
      }
      .hub-card {
        display: block;
        background: rgba(0,0,0,0.35);
        border: 1px solid rgba(255,255,255,0.08);
        border-left: 3px solid var(--hub-c, var(--p-cyan));
        border-radius: 2px;
        padding: 12px 14px;
        text-decoration: none;
        transition: transform 0.12s, border-color 0.12s, background 0.12s;
      }
      .hub-card:hover {
        transform: translateY(-2px);
        border-color: var(--hub-c, var(--p-cyan));
        background: rgba(0,0,0,0.45);
      }
      .hub-card-magenta { --hub-c: var(--p-magenta); }
      .hub-card-green   { --hub-c: var(--p-green); }
      .hub-card-cyan    { --hub-c: var(--p-cyan); }
      .hub-card-h {
        display: flex;
        align-items: baseline;
        gap: 8px;
        margin-bottom: 8px;
      }
      .hub-card-n {
        font-family: var(--font-mono);
        font-size: 11px;
        color: var(--hub-c, var(--p-cyan));
        font-weight: 700;
        letter-spacing: 0.04em;
      }
      .hub-card-title {
        font-family: var(--font-mono);
        font-size: 15px;
        font-weight: 700;
        color: var(--p-ink);
        flex: 1;
        letter-spacing: -0.01em;
      }
      .hub-card-arr {
        font-family: var(--font-mono);
        font-size: 12px;
        color: var(--hub-c, var(--p-cyan));
      }
      .hub-card-desc {
        font-size: 12.5px;
        line-height: 1.5;
        color: var(--p-ink);
        margin: 0 0 10px;
      }
      .hub-card-desc code {
        color: var(--p-orange);
        font-family: var(--font-mono);
        font-size: 11.5px;
      }
      .hub-card-desc b { color: var(--hub-c, var(--p-cyan)); }
      .hub-card-meta {
        display: flex;
        gap: 6px;
        font-family: var(--font-mono);
        font-size: 10px;
        color: var(--p-ink-faint);
        letter-spacing: 0.04em;
        flex-wrap: wrap;
      }

      /* file-system map */
      .fs-map {
        display: grid;
        gap: 14px;
        grid-template-columns: 1fr 1fr;
        margin: 10px 0;
      }
      @media (max-width: 720px) {
        .fs-map { grid-template-columns: 1fr; }
      }
      .fs-side {
        padding: 8px 10px;
        background: rgba(0, 0, 0, 0.3);
        border-left: 3px solid var(--c, var(--p-cyan));
        border-radius: 2px;
      }
      .fs-side h4 {
        font-family: var(--font-mono);
        font-size: 12px;
        color: var(--c, var(--p-cyan));
        margin: 0 0 4px;
        font-weight: 700;
      }
      .fs-tag {
        font-family: var(--font-mono);
        font-size: 9.5px;
        font-weight: 400;
        color: var(--p-ink-faint);
        font-style: italic;
        letter-spacing: 0.04em;
        margin-left: 4px;
      }
      .fs-tree {
        font-family: var(--font-mono);
        font-size: 10.5px;
        line-height: 1.55;
        color: var(--p-ink);
        margin: 0;
        white-space: pre;
      }
      .fs-tree .fs-dir {
        color: var(--c, var(--p-cyan));
        font-weight: 600;
      }
      .fs-tree .fs-key {
        color: var(--p-orange);
      }
      .fs-tree .fs-dim {
        color: var(--p-ink-faint);
      }
      .fs-tree .fs-section {
        color: var(--c, var(--p-cyan));
        font-weight: 700;
        letter-spacing: 0.08em;
        font-size: 9.5px;
        text-transform: uppercase;
      }

      /* decision compass */
      .compass-trio {
        display: grid;
        gap: 14px;
        grid-template-columns: repeat(3, 1fr);
        margin: 10px 0;
      }
      @media (max-width: 900px) {
        .compass-trio { grid-template-columns: 1fr; }
      }
      .compass {
        padding: 6px 8px;
        background: rgba(0, 0, 0, 0.25);
        border: 1px dashed rgba(255, 255, 255, 0.1);
        border-radius: 2px;
      }
      .compass-h {
        font-family: var(--font-mono);
        font-size: 11px;
        font-weight: 700;
        letter-spacing: 0.1em;
        color: var(--c, var(--p-ink));
        margin: 0 0 6px;
      }

      /* hook radial */
      .hk-lines line, .mcp-lines line {
        stroke: rgba(0, 229, 255, 0.25);
        stroke-width: 1;
        stroke-dasharray: 2 3;
      }
      .mcp-lines line { stroke: rgba(255, 68, 255, 0.3); }
      .hk-hub {
        fill: rgba(0, 229, 255, 0.12);
        stroke: var(--p-cyan);
        stroke-width: 1.5;
      }
      .hk-hub-lbl {
        font-size: 14px;
        font-weight: 800;
        text-anchor: middle;
        fill: var(--p-cyan);
        letter-spacing: 0.08em;
      }
      .hk-hub-sub {
        font-size: 10px;
        text-anchor: middle;
        fill: var(--p-ink-faint);
        letter-spacing: 0.06em;
      }
      .hk-petal-box {
        fill: rgba(0, 0, 0, 0.55);
        stroke: var(--p-cyan);
        stroke-width: 1;
      }
      .hk-petal-cat {
        font-size: 10px;
        font-weight: 700;
        text-anchor: middle;
        fill: var(--p-cyan);
        letter-spacing: 0.04em;
      }
      .hk-petal-events {
        font-size: 9px;
        text-anchor: middle;
        fill: var(--p-ink);
      }
      .hk-petal-count {
        font-size: 9px;
        text-anchor: middle;
        fill: var(--p-ink-faint);
        font-style: italic;
      }

      /* MCP radial — same shape, magenta theme */
      .mcp-hub {
        fill: rgba(255, 68, 255, 0.12);
        stroke: var(--p-magenta);
        stroke-width: 1.5;
      }
      .mcp-hub-lbl {
        font-size: 16px;
        font-weight: 800;
        text-anchor: middle;
        fill: var(--p-magenta);
        letter-spacing: 0.1em;
      }
      .mcp-hub-sub {
        font-size: 10px;
        text-anchor: middle;
        fill: var(--p-ink-faint);
        letter-spacing: 0.06em;
      }
      .mcp-srv-box {
        fill: rgba(0, 0, 0, 0.55);
        stroke: var(--p-magenta);
        stroke-width: 1;
      }
      .mcp-srv-name {
        font-size: 11px;
        font-weight: 800;
        text-anchor: middle;
        fill: var(--p-magenta);
        letter-spacing: 0.04em;
      }
      .mcp-srv-tool {
        font-size: 9px;
        text-anchor: middle;
        fill: var(--p-ink);
      }
      .mcp-srv-purpose {
        font-size: 9px;
        text-anchor: middle;
        fill: var(--p-ink-faint);
        font-style: italic;
        letter-spacing: 0.04em;
      }

      /* Cost matrix */
      .mx-col-h {
        font-size: 13px;
        font-weight: 800;
        text-anchor: middle;
        letter-spacing: 0.08em;
      }
      .mx-sub {
        font-size: 9.5px;
        text-anchor: middle;
        fill: var(--p-ink-faint);
        letter-spacing: 0.04em;
      }
      .mx-row-h {
        font-size: 11px;
        font-weight: 700;
        text-anchor: end;
        fill: var(--p-ink);
        letter-spacing: 0.04em;
      }
      .mx-cell.good { fill: rgba(57, 255, 20, 0.15); stroke: var(--p-green); stroke-width: 1.5; }
      .mx-cell.mid  { fill: rgba(255, 215, 0, 0.1);   stroke: var(--p-yellow); stroke-width: 1; }
      .mx-cell.bad  { fill: rgba(255, 77, 77, 0.08);   stroke: var(--p-red); stroke-width: 1; stroke-dasharray: 3 2; }
      .mx-cell-lbl {
        font-size: 11.5px;
        font-weight: 700;
        text-anchor: middle;
        letter-spacing: 0.06em;
      }
      .mx-cell-lbl.good { fill: var(--p-green); }
      .mx-cell-lbl.mid  { fill: var(--p-yellow); }
      .mx-cell-lbl.bad  { fill: var(--p-red); }
      .mx-cell-sub {
        font-size: 9.5px;
        text-anchor: middle;
        fill: var(--p-ink-dim);
      }

      /* Hook fire heatmap */
      .hf-axis { stroke: rgba(255, 255, 255, 0.2); stroke-width: 1; }
      .hf-name {
        font-size: 10.5px;
        text-anchor: end;
        fill: var(--p-ink);
        font-family: var(--font-mono);
      }
      .hf-rect { rx: 2; stroke-width: 0.5; }
      .hf-hot  { fill: rgba(255, 77, 77, 0.7); stroke: var(--p-red); }
      .hf-warm { fill: rgba(255, 153, 51, 0.6); stroke: var(--p-orange); }
      .hf-cool { fill: rgba(0, 229, 255, 0.5); stroke: var(--p-cyan); }
      .hf-cold { fill: rgba(155, 135, 245, 0.4); stroke: var(--p-violet); }
      .hf-count {
        font-size: 10px;
        font-weight: 700;
        fill: var(--p-ink);
        font-family: var(--font-mono);
      }

      /* Composition graph */
      .cg-layer {
        font-size: 10px;
        font-weight: 800;
        letter-spacing: 0.16em;
        fill: var(--p-ink-faint);
      }

      /* Session state */
      .ss-state {
        stroke-width: 2;
      }
      .ss-state.ss-start  { fill: rgba(57, 255, 20, 0.15); stroke: var(--p-green); }
      .ss-state.ss-active { fill: rgba(255, 153, 51, 0.18); stroke: var(--p-orange); stroke-width: 2.5; }
      .ss-state.ss-alt    { fill: rgba(0, 229, 255, 0.12); stroke: var(--p-cyan); }
      .ss-state.ss-end    { fill: rgba(255, 77, 77, 0.12); stroke: var(--p-red); }
      .ss-lbl {
        font-size: 11.5px;
        font-weight: 700;
        text-anchor: middle;
        fill: var(--p-ink);
        letter-spacing: 0.04em;
      }
      .ss-lbl-big {
        font-size: 13px;
      }
      .ss-sub {
        font-size: 9.5px;
        text-anchor: middle;
        fill: var(--p-ink-faint);
        font-style: italic;
      }
      .ss-arr {
        stroke: var(--p-ink-dim);
        stroke-width: 1.4;
        fill: none;
        color: var(--p-ink-dim);
      }
      .ss-arr-lbl {
        font-size: 10px;
        font-weight: 600;
        text-anchor: middle;
        fill: var(--p-ink);
        font-family: var(--font-mono);
      }

      /* ===== PART III MARKER (cyan variant) ===== */
      .part-marker-cyan {
        border-left-color: var(--p-cyan);
        background: linear-gradient(90deg, rgba(0, 229, 255, 0.08), transparent);
      }
      .part-tag-cyan {
        background: var(--p-cyan);
      }
      .part-marker-cyan .part-h code {
        color: var(--p-cyan);
        background: rgba(0, 229, 255, 0.08);
      }

      /* ===== PART IV MARKER (violet variant) ===== */
      .part-marker-violet {
        border-left-color: var(--p-violet);
        background: linear-gradient(90deg, rgba(155, 135, 245, 0.1), transparent);
      }
      .part-tag-violet {
        background: var(--p-violet);
      }
      .part-marker-violet .part-h code {
        color: var(--p-violet);
        background: rgba(155, 135, 245, 0.08);
      }

      /* ===== ATLAS SECTION ===== */
      .atlas-section {
        display: grid;
        gap: 14px;
        margin-top: 14px;
      }

      /* ===== LIFECYCLE SECTION ===== */
      .lifecycle-section {
        margin-top: 14px;
      }
      .diagram-wrap {
        margin: 12px 0 16px;
        overflow-x: auto;
        padding-bottom: 4px;
        scrollbar-color: var(--p-cyan) rgba(0,0,0,0.3);
      }
      .lifecycle-svg {
        display: block;
        width: 100%;
        min-width: 900px;
        height: auto;
        font-family: var(--font-mono);
      }

      /* SVG — lifelines */
      .lifelines line {
        stroke: rgba(255, 255, 255, 0.18);
        stroke-width: 1;
        stroke-dasharray: 4 4;
      }

      /* SVG — phase bands */
      .band {
        fill: rgba(255, 255, 255, 0.015);
        stroke: rgba(255, 255, 255, 0.06);
        stroke-width: 1;
      }
      .band-input { fill: rgba(57, 255, 20, 0.04); }
      .band-model { fill: rgba(0, 229, 255, 0.04); }
      .band-loop  { fill: rgba(255, 153, 51, 0.04); stroke: rgba(255, 153, 51, 0.18); stroke-dasharray: 5 4; }
      .band-sub   { fill: rgba(155, 135, 245, 0.05); }
      .band-stop  { fill: rgba(255, 215, 0, 0.04); }

      .phase-label {
        font-size: 11px;
        font-weight: 700;
        letter-spacing: 0.14em;
        fill: var(--p-ink);
      }
      .loop-hint {
        font-size: 10px;
        font-weight: 400;
        letter-spacing: 0.04em;
        fill: var(--p-orange);
      }

      /* SVG — lane headers */
      .lane-box {
        fill: rgba(0, 0, 0, 0.4);
        stroke: rgba(255, 255, 255, 0.25);
        stroke-width: 1;
      }
      .lane-box.user  { stroke: var(--p-green);   fill: rgba(57, 255, 20, 0.1); }
      .lane-box.orch  { stroke: var(--p-orange);  fill: rgba(255, 153, 51, 0.1); }
      .lane-box.hooks { stroke: var(--p-cyan);    fill: rgba(0, 229, 255, 0.1); }
      .lane-box.model { stroke: var(--p-magenta); fill: rgba(255, 68, 255, 0.1); }
      .lane-box.tool  { stroke: var(--p-yellow);  fill: rgba(255, 215, 0, 0.1); }
      .lane-box.sub   { stroke: var(--p-violet);  fill: rgba(155, 135, 245, 0.1); }

      .lane-label {
        font-size: 11.5px;
        font-weight: 800;
        letter-spacing: 0.14em;
        fill: var(--p-ink);
        text-anchor: middle;
      }
      .lane-sub {
        font-size: 9px;
        fill: var(--p-ink-faint);
        text-anchor: middle;
        letter-spacing: 0.06em;
      }

      /* SVG — messages (arrows) */
      .msg {
        stroke: var(--p-ink);
        stroke-width: 1.4;
        color: var(--p-ink);
        fill: none;
      }
      .msg.dashed {
        stroke-dasharray: 3 3;
        stroke: var(--p-ink-dim);
        color: var(--p-ink-dim);
      }
      .msg-d {
        stroke: rgba(156, 163, 175, 0.5);
        stroke-width: 1;
        stroke-dasharray: 2 3;
        color: rgba(156, 163, 175, 1);
        fill: none;
      }
      .msg-label {
        font-size: 10px;
        fill: var(--p-ink);
        text-anchor: middle;
        letter-spacing: 0.02em;
      }
      .note {
        font-size: 10px;
        fill: var(--p-ink-faint);
        font-style: italic;
      }
      .emph {
        fill: var(--p-violet);
        font-weight: 700;
      }

      /* SVG — hook badges */
      .hook-badge rect {
        fill: rgba(0, 229, 255, 0.12);
        stroke: var(--p-cyan);
        stroke-width: 0.8;
        rx: 2;
      }
      .hook-badge text {
        font-size: 10px;
        font-weight: 600;
        fill: var(--p-cyan);
        text-anchor: middle;
        letter-spacing: 0.02em;
      }
      .hook-badge.ok rect {
        fill: rgba(57, 255, 20, 0.12);
        stroke: var(--p-green);
      }
      .hook-badge.ok text { fill: var(--p-green); }
      .hook-badge.warn rect {
        fill: rgba(255, 77, 77, 0.12);
        stroke: var(--p-red);
      }
      .hook-badge.warn text { fill: var(--p-red); }
      .hook-badge.dim rect {
        fill: rgba(255, 255, 255, 0.04);
        stroke: rgba(255, 255, 255, 0.2);
      }
      .hook-badge.dim text { fill: var(--p-ink-dim); }

      .if {
        font-size: 9px;
        font-weight: 400;
        fill: var(--p-ink-faint);
        font-style: italic;
      }
      .block-tag {
        font-size: 9px;
        font-weight: 700;
        fill: var(--p-red);
        letter-spacing: 0.1em;
      }

      /* SVG — loop arrow */
      .loop-arrow {
        stroke: var(--p-orange);
        stroke-width: 1.6;
        stroke-dasharray: 6 3;
        fill: none;
        color: var(--p-orange);
      }
      .loop-label {
        font-size: 9.5px;
        letter-spacing: 0.08em;
        font-weight: 600;
        fill: var(--p-orange);
        text-anchor: middle;
      }

      /* ===== LEGEND ===== */
      .lifecycle-legend {
        display: grid;
        gap: 10px;
        grid-template-columns: repeat(3, 1fr);
        margin-top: 12px;
        padding-top: 12px;
        border-top: 1px dashed rgba(255, 255, 255, 0.08);
      }
      @media (max-width: 900px) {
        .lifecycle-legend { grid-template-columns: 1fr; }
      }
      .lg-block ul {
        list-style: none;
        padding: 0;
        margin: 4px 0 0;
      }
      .lg-block li {
        font-size: 11px;
        color: var(--p-ink-dim);
        line-height: 1.6;
        padding: 1px 0;
      }
      .lg-block code {
        color: var(--p-cyan);
        background: rgba(0, 229, 255, 0.06);
        padding: 0 4px;
        border-radius: 2px;
        font-size: 10.5px;
      }
      .lg-h {
        display: block;
        font-family: var(--font-mono);
        font-size: 10.5px;
        letter-spacing: 0.12em;
        font-weight: 700;
        color: var(--p-cyan);
        margin-bottom: 4px;
        padding-bottom: 4px;
        border-bottom: 1px dashed rgba(0, 229, 255, 0.25);
      }
      .lg-swatch {
        display: inline-block;
        width: 10px;
        height: 10px;
        border-radius: 2px;
        vertical-align: middle;
        margin-right: 4px;
      }
      .lg-swatch.ok   { background: var(--p-green); }
      .lg-swatch.warn { background: var(--p-red); }
      .lg-arr {
        display: inline-block;
        width: 14px;
        color: var(--p-ink);
        font-weight: 700;
      }
      .lg-arr.d { color: var(--p-ink-dim); }
      .lg-arr.l { color: var(--p-orange); }

      /* ===== CARDS ===== */
      .card {
        --c: var(--p-green);
        border: 1px solid var(--c);
        background: rgba(10, 14, 31, 0.6);
        padding: 14px 16px 16px;
        position: relative;
      }
      .card::before {
        content: "";
        position: absolute;
        inset: 0;
        border: 1px solid rgba(255, 255, 255, 0.04);
        pointer-events: none;
      }
      .card-green   { --c: var(--p-green); }
      .card-orange  { --c: var(--p-orange); }
      .card-red     { --c: var(--p-red); }
      .card-cyan    { --c: var(--p-cyan); }
      .card-magenta { --c: var(--p-magenta); }
      .card-yellow  { --c: var(--p-yellow); }
      .card-violet  { --c: var(--p-violet); }
      .card-pink    { --c: var(--p-pink); }

      .card-h {
        font-family: var(--font-mono);
        font-size: 13px;
        font-weight: 700;
        letter-spacing: 0.14em;
        color: var(--c);
        margin: 0 0 2px;
        text-shadow: 0 0 12px color-mix(in srgb, var(--c) 40%, transparent);
      }
      .card-sub {
        font-size: 11px;
        color: var(--p-ink-faint);
        margin: 0 0 12px;
        letter-spacing: 0.04em;
      }

      /* ===== FLAGS DL ===== */
      .flags {
        margin: 0;
        display: grid;
        gap: 6px 12px;
      }
      .flags.two-col {
        grid-template-columns: 1fr;
      }
      @media (min-width: 720px) {
        .flags.two-col { grid-template-columns: 1fr 1fr; }
      }

      .flags dt {
        font-family: var(--font-mono);
        font-size: 12px;
        color: var(--p-ink);
        margin-top: 4px;
        line-height: 1.3;
      }
      .flags dt code {
        color: color-mix(in srgb, var(--c) 85%, white);
        font-weight: 600;
      }
      .flags dt.warn code,
      .flags dt.warn {
        color: var(--p-red) !important;
      }
      .flags dt.hot code {
        color: var(--p-orange);
      }
      .flags dt.dim code,
      .flags dt.dim {
        color: var(--p-ink-faint);
        text-decoration: line-through;
      }

      .flags dd {
        margin: 0 0 4px 14px;
        font-size: 11.5px;
        color: var(--p-ink-dim);
        line-height: 1.5;
      }
      .flags dd.dim { color: var(--p-ink-faint); }
      .flags dd code {
        color: var(--p-green);
        background: rgba(57, 255, 20, 0.06);
        padding: 0 4px;
        border-radius: 2px;
        font-size: 11px;
      }
      .arg {
        color: var(--p-ink-faint);
        font-weight: 400;
      }
      .kv {
        display: inline-block;
        font-family: var(--font-mono);
        font-size: 10.5px;
        color: var(--p-cyan);
        background: rgba(0, 229, 255, 0.08);
        border: 1px solid rgba(0, 229, 255, 0.25);
        padding: 0 4px;
        margin: 1px 2px 1px 0;
        border-radius: 2px;
      }
      .kv.warn {
        color: var(--p-red);
        background: rgba(255, 77, 77, 0.08);
        border-color: rgba(255, 77, 77, 0.3);
      }
      .dim {
        color: var(--p-ink-faint);
      }

      .recipe {
        margin-top: 10px;
        font-size: 11px;
        color: var(--p-ink-dim);
        padding-top: 10px;
        border-top: 1px dashed rgba(255, 255, 255, 0.08);
      }
      .recipe-h {
        display: block;
        color: var(--p-ink-faint);
        font-size: 10px;
        letter-spacing: 0.08em;
        margin-bottom: 4px;
      }
      .recipe code {
        color: var(--p-orange);
      }

      /* ===== SETTINGS — chain + snippet ===== */
      .chain {
        list-style: none;
        margin: 4px 0 6px;
        padding: 0;
        counter-reset: chain;
      }
      .chain li {
        position: relative;
        padding: 4px 4px 4px 26px;
        font-size: 12px;
        color: var(--p-ink);
        counter-increment: chain;
        border-bottom: 1px dashed rgba(255, 255, 255, 0.05);
      }
      .chain li:last-child { border-bottom: none; }
      .chain li::before {
        content: counter(chain);
        position: absolute;
        left: 0;
        top: 4px;
        font-family: var(--font-mono);
        font-size: 10px;
        font-weight: 700;
        color: var(--p-orange);
        background: rgba(255, 153, 51, 0.1);
        border: 1px solid rgba(255, 153, 51, 0.3);
        width: 18px;
        height: 18px;
        line-height: 16px;
        text-align: center;
        border-radius: 2px;
      }
      .chain code {
        color: var(--p-orange);
        background: rgba(255, 153, 51, 0.08);
        padding: 0 4px;
        border-radius: 2px;
        font-size: 11.5px;
      }
      .snippet {
        margin-top: 10px;
        padding: 8px 10px;
        background: rgba(0, 0, 0, 0.35);
        border-left: 2px solid var(--p-orange);
        font-size: 11px;
      }
      .snippet pre {
        margin: 4px 0 0;
        overflow-x: auto;
        white-space: pre;
        color: var(--p-ink);
      }
      .snippet pre code {
        background: none;
        color: var(--p-ink);
      }

      /* ===== HOOKS — groups + rules ===== */
      .hooks-groups {
        display: flex;
        flex-direction: column;
        gap: 6px;
        margin-bottom: 12px;
      }
      .hg {
        font-size: 11.5px;
        line-height: 1.65;
        color: var(--p-ink-dim);
        padding-left: 8px;
        border-left: 2px solid rgba(0, 229, 255, 0.25);
      }
      .hg-h {
        display: block;
        font-family: var(--font-mono);
        font-size: 10.5px;
        letter-spacing: 0.1em;
        font-weight: 700;
        color: var(--p-cyan);
        margin-bottom: 2px;
      }
      .hg code {
        color: var(--p-ink);
        background: rgba(0, 229, 255, 0.06);
        border: 1px solid rgba(0, 229, 255, 0.2);
        padding: 1px 4px;
        margin: 1px 1px 1px 0;
        border-radius: 2px;
        font-size: 10.5px;
        display: inline-block;
        white-space: nowrap;
      }
      .hooks-rules {
        display: grid;
        gap: 8px;
        grid-template-columns: repeat(3, 1fr);
        padding-top: 8px;
        border-top: 1px dashed rgba(255, 255, 255, 0.08);
      }
      @media (max-width: 900px) {
        .hooks-rules { grid-template-columns: 1fr; }
      }
      .hr-block p {
        margin: 4px 0 0;
        font-size: 11px;
        color: var(--p-ink-dim);
        line-height: 1.55;
      }
      .hr-block code {
        color: var(--p-cyan);
        background: rgba(0, 229, 255, 0.06);
        padding: 0 3px;
        border-radius: 2px;
        font-size: 10.5px;
      }
      .recipe-h.warn {
        color: var(--p-red);
      }

      /* ===== SKILLS / AGENTS — frontmatter snippets ===== */
      .fm-pre {
        margin: 4px 0 0;
        padding: 6px 8px;
        background: rgba(0, 0, 0, 0.35);
        border-left: 2px solid var(--c, var(--p-magenta));
        font-size: 10.5px;
        line-height: 1.5;
        color: var(--p-ink);
        overflow-x: auto;
        white-space: pre;
      }
      .fm-pre code {
        background: none;
        color: var(--p-ink);
        font-family: var(--font-mono);
      }
      .builtins {
        list-style: none;
        margin: 4px 0 0;
        padding: 0;
      }
      .builtins li {
        font-size: 11px;
        color: var(--p-ink-dim);
        line-height: 1.6;
        padding-left: 10px;
        position: relative;
      }
      .builtins li::before {
        content: "›";
        color: var(--p-violet);
        position: absolute;
        left: 0;
      }
      .builtins code {
        color: var(--p-violet);
        background: rgba(155, 135, 245, 0.08);
        padding: 0 4px;
        border-radius: 2px;
        font-size: 10.5px;
      }
      .mini {
        font-size: 11px;
        color: var(--p-ink-dim);
        line-height: 1.55;
        margin: 4px 0 0;
      }
      .mini code {
        color: var(--c, var(--p-violet));
        background: rgba(255, 255, 255, 0.04);
        padding: 0 3px;
        border-radius: 2px;
        font-size: 10.5px;
      }

      /* ===== COMMANDS — columns ===== */
      .cmd-cols {
        display: grid;
        gap: 14px 18px;
        grid-template-columns: repeat(4, 1fr);
      }
      @media (max-width: 1100px) {
        .cmd-cols { grid-template-columns: repeat(3, 1fr); }
      }
      @media (max-width: 800px) {
        .cmd-cols { grid-template-columns: repeat(2, 1fr); }
      }
      @media (max-width: 480px) {
        .cmd-cols { grid-template-columns: 1fr; }
      }
      .cmd-h {
        display: block;
        font-family: var(--font-mono);
        font-size: 10.5px;
        letter-spacing: 0.12em;
        font-weight: 700;
        color: var(--p-yellow);
        margin-bottom: 4px;
        padding-bottom: 4px;
        border-bottom: 1px dashed rgba(255, 215, 0, 0.25);
      }
      .cmd-list {
        list-style: none;
        margin: 0;
        padding: 0;
      }
      .cmd-list li {
        font-size: 11px;
        color: var(--p-ink-dim);
        line-height: 1.5;
        padding: 1px 0;
      }
      .cmd-list li code {
        color: var(--p-yellow);
        background: rgba(255, 215, 0, 0.06);
        padding: 0 3px;
        border-radius: 2px;
        font-size: 10.5px;
        margin-right: 4px;
      }
      .cmd-list li.hot code {
        color: var(--p-orange);
        background: rgba(255, 153, 51, 0.08);
      }

      /* ===== RECIPES BLOCK ===== */
      .recipes {
        display: grid;
        gap: 10px;
        grid-template-columns: repeat(2, 1fr);
      }
      @media (max-width: 800px) {
        .recipes { grid-template-columns: 1fr; }
      }
      .recipe-block {
        border-left: 2px solid var(--p-green);
        padding: 6px 10px;
        background: rgba(57, 255, 20, 0.03);
      }
      .recipe-block pre {
        margin: 4px 0 0;
        font-size: 11.5px;
        color: var(--p-ink);
        overflow-x: auto;
        white-space: pre;
      }
      .recipe-block pre code {
        background: none;
        color: var(--p-ink);
        font-family: var(--font-mono);
      }

      /* ===== BOTTOM ===== */
      .bottom {
        margin-top: 24px;
      }
      .bottom-band {
        display: flex;
        align-items: center;
        justify-content: center;
        gap: 22px;
        padding: 14px 12px;
        border: 1px solid var(--p-green);
        background: linear-gradient(90deg, rgba(57, 255, 20, 0.06), transparent, rgba(255, 153, 51, 0.06));
        flex-wrap: wrap;
      }
      .b-tag {
        font-family: var(--font-mono);
        font-size: 12px;
        letter-spacing: 0.16em;
        color: var(--p-ink);
        font-weight: 700;
      }
      .sep {
        color: var(--p-ink-faint);
      }
      .meta {
        margin-top: 12px;
        text-align: center;
        font-size: 11px;
        color: var(--p-ink-faint);
        letter-spacing: 0.04em;
      }
      .meta a {
        color: var(--p-green);
      }
      .meta a:hover {
        text-decoration: underline;
      }
      .meta code {
        color: var(--p-orange);
      }

      /* Print stylesheet — one A3 sheet */
      @media print {
        .back-link { display: none; }
        .poster-body { background: white; color: black; padding: 0; }
        .poster {
          border: none;
          padding: 8mm;
          max-width: none;
        }
        .card { background: white; color: black; }
        .flags dt, .flags dd { color: black; }
      }
    </style>

    <script is:inline>
      (() => {
        const body = document.body;
        const search = document.getElementById("cs-search");
        const myth = document.getElementById("cs-myth");
        const pdf = document.getElementById("cs-pdf");
        const cards = Array.from(document.querySelectorAll("article.card"));

        // Fuzzy search — dim non-matching cards
        if (search) {
          const apply = () => {
            const q = search.value.toLowerCase().trim();
            if (!q) {
              body.classList.remove("search-active");
              cards.forEach((c) => c.classList.remove("search-match"));
              return;
            }
            body.classList.add("search-active");
            cards.forEach((c) => {
              const txt = (c.textContent || "").toLowerCase();
              c.classList.toggle("search-match", txt.includes(q));
            });
          };
          search.addEventListener("input", apply);
          document.addEventListener("keydown", (e) => {
            const t = e.target;
            const inField =
              t && (t.tagName === "INPUT" || t.tagName === "TEXTAREA");
            if (e.key === "/" && !inField) {
              e.preventDefault();
              search.focus();
              search.select();
            } else if (e.key === "Escape" && document.activeElement === search) {
              search.value = "";
              apply();
              search.blur();
            }
          });
        }

        // Mythology mode toggle
        if (myth) {
          myth.addEventListener("click", () => {
            const on = body.classList.toggle("myth-mode");
            myth.setAttribute("aria-pressed", on ? "true" : "false");
          });
        }

        // PDF / print
        if (pdf) {
          pdf.addEventListener("click", () => window.print());
        }

        // Lifecycle SVG animation on scroll-into-view
        const svg = document.querySelector(".lifecycle-svg");
        if (svg) {
          if ("IntersectionObserver" in window) {
            const io = new IntersectionObserver(
              (entries) => {
                entries.forEach((e) => {
                  if (e.isIntersecting) {
                    svg.classList.add("in-view");
                    io.disconnect();
                  }
                });
              },
              { threshold: 0.18 },
            );
            io.observe(svg);
          } else {
            svg.classList.add("in-view");
          }
        }
      })();
    </script>
  </body>
</html>
