    <style is:global>
      :root[data-theme="poster"] {
        --p-bg: #0a0e1f;
        --p-bg-2: #0e1530;
        --p-ink: #e5e7eb;
        --p-ink-dim: #9ca3af;
        --p-ink-faint: #6b7280;
        --p-green: #39ff14;
        --p-orange: #ff9933;
        --p-red: #ff4d4d;
        --p-cyan: #00e5ff;
        --p-magenta: #ff44ff;
        --p-yellow: #ffd700;
        --p-violet: #9b87f5;
        --p-pink: #ff5cad;
      }

      html[data-theme="poster"],
      html[data-theme="poster"] body {
        background: var(--p-bg) !important;
        color: var(--p-ink) !important;
      }

      html, body { overflow-x: clip; }
      .poster-body {
        font-family: var(--font-mono);
        background:
          radial-gradient(ellipse at top, rgba(57, 255, 20, 0.04), transparent 60%),
          radial-gradient(ellipse at bottom right, rgba(255, 153, 51, 0.04), transparent 60%),
          var(--p-bg);
        min-height: 100vh;
        color: var(--p-ink);
        padding: 16px;
        overflow-x: clip;
        overflow-wrap: anywhere;
        max-width: 100%;
      }

      .back-link {
        display: inline-block;
        font-family: var(--font-mono);
        font-size: 12px;
        color: var(--p-ink-dim);
        padding: 6px 10px;
        border: 1px solid rgba(255, 255, 255, 0.12);
        border-radius: 3px;
        transition: all 120ms ease;
      }
      .back-link:hover {
        color: var(--p-green);
        border-color: var(--p-green);
      }

      /* ===== TOP ROW + TOOLBAR ===== */
      .top-row {
        display: flex;
        align-items: center;
        gap: 10px;
        margin-bottom: 12px;
        flex-wrap: wrap;
      }
      .cs-toolbar {
        display: flex;
        align-items: center;
        gap: 6px;
        flex: 1;
        min-width: 280px;
      }
      .cs-toolbar input {
        flex: 1;
        background: rgba(0, 0, 0, 0.4);
        border: 1px solid rgba(255, 255, 255, 0.12);
        color: var(--p-ink);
        padding: 6px 12px;
        border-radius: 3px;
        font-family: var(--font-mono);
        font-size: 12px;
        outline: none;
        transition: border-color 120ms;
        min-width: 0;
      }
      .cs-toolbar input::placeholder { color: var(--p-ink-faint); }
      .cs-toolbar input:focus { border-color: var(--p-green); }
      .cs-toolbar input::-webkit-search-cancel-button { display: none; }
      .cs-toolbar button {
        background: rgba(0, 0, 0, 0.4);
        border: 1px solid rgba(255, 255, 255, 0.12);
        color: var(--p-ink-dim);
        padding: 6px 12px;
        border-radius: 3px;
        font-family: var(--font-mono);
        font-size: 11px;
        cursor: pointer;
        letter-spacing: 0.04em;
        transition: all 120ms;
        white-space: nowrap;
      }
      .cs-toolbar button:hover {
        border-color: var(--p-orange);
        color: var(--p-orange);
      }
      .cs-toolbar button[aria-pressed="true"] {
        border-color: var(--p-magenta);
        color: var(--p-magenta);
        background: rgba(255, 68, 255, 0.06);
      }

      /* ===== SEARCH DIMMING ===== */
      .card {
        transition: opacity 200ms ease, transform 200ms ease, box-shadow 200ms ease;
      }
      body.search-active article.card:not(.search-match) {
        opacity: 0.12;
        transform: scale(0.99);
      }
      body.search-active article.card.search-match {
        box-shadow: 0 0 24px color-mix(in srgb, var(--c, var(--p-green)) 35%, transparent);
      }
      body.search-active .part-marker,
      body.search-active .recipes-section,
      body.search-active .lifecycle-section,
      body.search-active .bottom {
        opacity: 0.35;
      }

      /* ===== MYTHOLOGY MODE ===== */
      body.myth-mode .card-h[data-myth-icon] {
        display: inline-flex;
        align-items: baseline;
        gap: 8px;
        flex-wrap: wrap;
      }
      body.myth-mode .card-h[data-myth-icon]::before {
        content: attr(data-myth-icon);
        font-size: 1.5em;
        line-height: 1;
        filter: drop-shadow(0 0 6px color-mix(in srgb, var(--c, var(--p-green)) 60%, transparent));
      }
      body.myth-mode .card-h[data-myth-name]::after {
        content: "· " attr(data-myth-name);
        font-family: var(--font-mono);
        font-weight: 500;
        color: var(--p-ink-faint);
        font-size: 0.78em;
        font-style: italic;
        letter-spacing: 0.05em;
        opacity: 0.85;
      }

      /* ===== LIFECYCLE ANIMATION ===== */
      /* Lines: animate via stroke-dashoffset (safe — no transform clobber) */
      .lifecycle-svg .msg,
      .lifecycle-svg .msg-d,
      .lifecycle-svg .loop-arrow {
        stroke-dasharray: 100;
        stroke-dashoffset: 100;
      }
      /* SVG <g> and <text> with transform attribute: opacity-only fade */
      .lifecycle-svg .msg-label,
      .lifecycle-svg .note,
      .lifecycle-svg .hook-badge,
      .lifecycle-svg .loop-label {
        opacity: 0;
      }
      .lifecycle-svg.in-view .msg,
      .lifecycle-svg.in-view .msg-d,
      .lifecycle-svg.in-view .loop-arrow {
        animation: cs-line-draw 0.55s ease-out forwards;
        animation-delay: calc(var(--step, 0) * 0.18s);
      }
      .lifecycle-svg.in-view .msg-label,
      .lifecycle-svg.in-view .note,
      .lifecycle-svg.in-view .hook-badge,
      .lifecycle-svg.in-view .loop-label {
        animation: cs-appear 0.45s ease-out forwards;
        animation-delay: calc(var(--step, 0) * 0.18s + 0.1s);
      }
      @keyframes cs-line-draw {
        to { stroke-dashoffset: 0; }
      }
      @keyframes cs-appear {
        from { opacity: 0; }
        to { opacity: 1; }
      }
      @media (prefers-reduced-motion: reduce) {
        .lifecycle-svg .msg,
        .lifecycle-svg .msg-d,
        .lifecycle-svg .loop-arrow {
          stroke-dashoffset: 0;
        }
        .lifecycle-svg .msg-label,
        .lifecycle-svg .note,
        .lifecycle-svg .hook-badge,
        .lifecycle-svg .loop-label {
          opacity: 1;
          animation: none;
        }
      }

      @media print {
        .top-row { gap: 0; margin-bottom: 8mm; }
        .cs-toolbar { display: none !important; }
        .back-link { display: none; }
        body.search-active article.card { opacity: 1 !important; transform: none !important; }
        body.search-active .part-marker,
        body.search-active .recipes-section,
        body.search-active .lifecycle-section,
        body.search-active .bottom { opacity: 1 !important; }
        /* Force lifecycle SVG to final state for print */
        .lifecycle-svg .msg,
        .lifecycle-svg .msg-d,
        .lifecycle-svg .loop-arrow { stroke-dashoffset: 0 !important; }
        .lifecycle-svg .msg-label,
        .lifecycle-svg .note,
        .lifecycle-svg .hook-badge,
        .lifecycle-svg .loop-label {
          opacity: 1 !important;
          transform: none !important;
          animation: none !important;
        }
      }

