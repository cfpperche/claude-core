              <text x="820" y="174" class="ss-sub">SessionEnd</text>

              <!-- Transitions -->
              <line x1="128" y1="160" x2="252" y2="160" class="ss-arr" marker-end="url(#ss)" />
              <text x="190" y="153" class="ss-arr-lbl">SessionStart</text>

              <path d="M 370 115 Q 480 50 552 60" class="ss-arr" marker-end="url(#ss)" fill="none" />
              <text x="475" y="80" class="ss-arr-lbl">/compact</text>

              <path d="M 552 80 Q 480 130 372 152" class="ss-arr" marker-end="url(#ss)" fill="none" />
              <text x="475" y="140" class="ss-arr-lbl">resume</text>

              <path d="M 370 205 Q 480 270 552 260" class="ss-arr" marker-end="url(#ss)" fill="none" />
              <text x="475" y="240" class="ss-arr-lbl">/clear</text>

              <path d="M 552 240 Q 480 200 372 184" class="ss-arr" marker-end="url(#ss)" fill="none" />
              <text x="475" y="200" class="ss-arr-lbl">resume</text>

              <line x1="382" y1="160" x2="776" y2="160" class="ss-arr" marker-end="url(#ss)" style="stroke:var(--p-red);color:var(--p-red)" />
              <text x="580" y="155" class="ss-arr-lbl" style="fill:var(--p-red)">/exit · Ctrl-D</text>

              <text x="450" y="310" class="dgm-lbl-sm" style="font-size:10px">
                SessionStart fires on each entry · source = startup · resume · clear · compact.
              </text>
            </svg>
          </div>
        </article>

        <!-- COMPACTION INTERRUPT FLOW -->
        <article id="compaction-flow" class="card card-red wide">
          <h2 class="card-h" data-myth-icon="🌀" data-myth-name="The Archive">▸ INTERRUPÇÃO DE COMPACTION — o que acontece em /compact</h2>
          <p class="card-sub">como o sinal cru sobrevive à sumarização · a ponte PreCompact → SessionStart(compact)</p>
          <div style="display:flex;justify-content:center;padding:10px 0">
            <svg class="dgm-svg cmp-flow" viewBox="0 0 1100 260" xmlns="http://www.w3.org/2000/svg" style="max-width:1100px">
              <defs>
                <marker id="cm" viewBox="0 0 10 10" refX="9" refY="5" markerWidth="6" markerHeight="6" orient="auto"><path d="M0,0 L10,5 L0,10 z" fill="var(--p-ink-dim)" /></marker>
              </defs>

              <!-- Step 1: turn N nearing budget -->
              <g transform="translate(10, 80)">
                <rect width="170" height="80" rx="3" class="dgm-box dgm-box-cyan" />
                <text x="85" y="20" class="dgm-lbl-sm">step 1 · trigger</text>
                <text x="85" y="40" class="dgm-lbl">turn N</text>
                <text x="85" y="58" class="dgm-lbl-sm">token budget</text>
                <text x="85" y="72" class="dgm-lbl-sm">approaching limit</text>
              </g>
              <line x1="190" y1="120" x2="214" y2="120" class="dgm-arr" marker-end="url(#cm)" />

              <!-- Step 2: PreCompact -->
              <g transform="translate(220, 80)">
                <rect width="170" height="80" rx="3" class="dgm-box dgm-box-orange" />
                <text x="85" y="20" class="dgm-lbl-sm">step 2 · capture</text>
                <text x="85" y="40" class="dgm-lbl">PreCompact</text>
                <text x="85" y="58" class="dgm-lbl-sm">snapshot raw turns</text>
                <text x="85" y="72" class="dgm-lbl-sm">→ COMPACT_NOTES.md</text>
              </g>
              <line x1="400" y1="120" x2="424" y2="120" class="dgm-arr" marker-end="url(#cm)" />

              <!-- Step 3: summarizer runs -->
              <g transform="translate(430, 80)">
                <rect width="170" height="80" rx="3" class="dgm-box dgm-box-magenta" />
                <text x="85" y="20" class="dgm-lbl-sm">step 3 · summarize</text>
                <text x="85" y="40" class="dgm-lbl">summarizer</text>
                <text x="85" y="58" class="dgm-lbl-sm">model compresses</text>
                <text x="85" y="72" class="dgm-lbl-sm">conversation history</text>
              </g>
              <line x1="610" y1="120" x2="634" y2="120" class="dgm-arr" marker-end="url(#cm)" />

              <!-- Step 4: PostCompact -->
              <g transform="translate(640, 80)">
                <rect width="170" height="80" rx="3" class="dgm-box dgm-box-yellow" />
                <text x="85" y="20" class="dgm-lbl-sm">step 4 · settle</text>
                <text x="85" y="40" class="dgm-lbl">PostCompact</text>
                <text x="85" y="58" class="dgm-lbl-sm">summary committed</text>
                <text x="85" y="72" class="dgm-lbl-sm">old turns trimmed</text>
              </g>
              <line x1="820" y1="120" x2="844" y2="120" class="dgm-arr" marker-end="url(#cm)" />

              <!-- Step 5: SessionStart(compact) -->
              <g transform="translate(850, 80)">
                <rect width="240" height="80" rx="3" class="dgm-box dgm-box-green" />
                <text x="120" y="20" class="dgm-lbl-sm">step 5 · re-inject</text>
                <text x="120" y="40" class="dgm-lbl">SessionStart(source:compact)</text>
                <text x="120" y="58" class="dgm-lbl-sm">re-loads COMPACT_NOTES.md</text>
                <text x="120" y="72" class="dgm-lbl-sm">raw signal preserved · turn N+1</text>
              </g>

              <!-- Top annotation -->
              <text x="550" y="30" class="dgm-lbl-sm" style="font-size:10.5px;font-weight:600">
                Why this matters: <tspan fill="var(--p-orange)">summarization is lossy</tspan> · only <tspan fill="var(--p-orange)">PreCompact</tspan> can write before truncation; only <tspan fill="var(--p-orange)">SessionStart</tspan> can inject after.
              </text>

              <!-- Bottom annotation -->
              <text x="550" y="200" class="dgm-lbl-sm" style="font-size:10px">
                Pattern: <tspan fill="var(--p-orange)">PreCompact</tspan> writes raw turns to a file on disk · <tspan fill="var(--p-orange)">SessionStart</tspan> with <tspan fill="var(--p-cyan)">source: "compact"</tspan> reads it back as <tspan fill="var(--p-green)">additionalContext</tspan>.
              </text>
              <text x="550" y="230" class="dgm-lbl-sm" style="font-size:9.5px;font-style:italic">
                Other hooks (PostToolUse, UserPromptSubmit) get baked into the transcript and replayed stale — useless for this purpose.
              </text>
            </svg>
          </div>
        </article>

      </section>

      <!-- ===== RECIPES — common combos ===== -->
      <section class="recipes-section">
        <article class="card card-green">
          <h2 class="card-h" data-myth-icon="🍳" data-myth-name="The Grimoire">▸ RECEITAS — COMBOS COMUNS</h2>
          <p class="card-sub">defaults copy-paste que pagam rápido</p>
          <div class="recipes">
            <div class="recipe-block">
              <span class="recipe-h"># continue last session in this dir</span>
              <pre><code>claude -c</code></pre>
            </div>
            <div class="recipe-block">
              <span class="recipe-h"># scriptable one-shot, structured output, budgeted</span>
              <pre><code>claude -p --output-format json --max-budget-usd 0.50 "summarize this diff"</code></pre>
            </div>
            <div class="recipe-block">
              <span class="recipe-h"># isolated branch, tmux pane</span>
              <pre><code>claude -w feature-x --tmux</code></pre>
            </div>
            <div class="recipe-block">
              <span class="recipe-h"># library mode — no harness, you bring context</span>
              <pre><code>claude --bare --append-system-prompt "$(cat prompt.md)" --add-dir ./src</code></pre>
            </div>
            <div class="recipe-block">
              <span class="recipe-h"># read-only with git-only Bash</span>
              <pre><code>claude --tools "Read,Bash" --allowedTools "Bash(git status),Bash(git diff)"</code></pre>
            </div>
            <div class="recipe-block">
              <span class="recipe-h"># debug MCP in isolation</span>
              <pre><code>claude --strict-mcp-config --mcp-config ./test-mcp.json --debug mcp</code></pre>
            </div>
            <div class="recipe-block">
              <span class="recipe-h"># headless PR review in GitHub Actions</span>
              <pre><code>claude -p --permission-mode bypassPermissions --output-format json --max-turns 6 \
  "review this PR for security issues, return findings as JSON"</code></pre>
            </div>
            <div class="recipe-block">
              <span class="recipe-h"># autonomous test-fix loop with hard budget cap</span>
              <pre><code>claude -p --max-turns 12 --max-budget-usd 1.00 \
  "run tests, fix failures, repeat until green"</code></pre>
            </div>
            <div class="recipe-block">
              <span class="recipe-h"># cheap mode: Haiku for formatting / docs</span>
              <pre><code>claude --model haiku --effort low "reformat all .md files to consistent style"</code></pre>
            </div>
          </div>
        </article>
      </section>

