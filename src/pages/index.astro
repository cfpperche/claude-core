---
import "../styles/global.css";
import { REPO_URL } from "../i18n/locales";
import LanguageSwitcher from "../components/LanguageSwitcher.astro";

const base = import.meta.env.BASE_URL.replace(/\/$/, "");
const siteUrl = "https://cfpperche.github.io";
const CC_VERSION = "2.1.143";
const pageTitle = `claude-core · A learning surface for Claude Code`;
const pageDesc = `Five free learning surfaces for Claude Code v${CC_VERSION}: a dense cheatsheet, a 12-module Master Class, an 8-module deep dive on /goal, a Hook Cookbook with 10 recipes, and a Routing Class covering CCRouter (extend the model layer).`;
---

<!doctype html>
<html lang="en" data-theme="poster">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{pageTitle}</title>
    <meta name="description" content={pageDesc} />
    <meta property="og:title" content={pageTitle} />
    <meta property="og:description" content={pageDesc} />
    <meta property="og:type" content="website" />
    <meta property="og:url" content={`${siteUrl}${base}/`} />
    <meta name="twitter:card" content="summary_large_image" />
    <link rel="icon" type="image/svg+xml" href={`${base}/favicon.svg`} />
  </head>
  <body class="ix-body">

    <div class="ix-top">
      <LanguageSwitcher
        enHref={`${base}/`}
        ptHref={`${base}/pt/`}
        esHref={`${base}/es/`}
        current="en"
      />
    </div>

    <main class="ix-page">

      <header class="ix-banner">
        <div class="ix-strip">
          <span class="ix-tag">▮ CLAUDE-CORE</span>
          <span class="ix-tag">CLAUDE CODE v{CC_VERSION}</span>
          <span class="ix-tag">FIVE FREE SURFACES ▮</span>
        </div>
        <h1 class="ix-title">
          <span class="ix-title-line">A LEARNING SURFACE</span>
          <span class="ix-title-line ix-title-accent">FOR CLAUDE CODE</span>
        </h1>
        <p class="ix-sub">
          Five free resources for getting deep on Anthropic's terminal-native coding agent. Pick by where you are — reference, guided walkthrough, deep dives, or copy-paste recipes.
        </p>
      </header>

      <section class="ix-grid">

        <a href={`${base}/cheatsheet/claude-core/`} class="ix-card ix-card-green">
          <div class="ix-card-head">
            <span class="ix-card-n">●</span>
            <h2 class="ix-card-h">Cheatsheet</h2>
            <span class="ix-card-arr" aria-hidden="true">↗</span>
          </div>
          <p class="ix-card-desc">
            Dense single-page poster. Every CLI flag, hook event, skill/agent surface, settings field, slash command. Ctrl-F friendly. Print as A3.
          </p>
          <div class="ix-card-meta">
            <span>1 page</span><span>·</span><span>~50 KB</span><span>·</span><span>printable</span>
          </div>
        </a>

        <a href={`${base}/masterclass/claude-code/`} class="ix-card ix-card-magenta">
          <div class="ix-card-head">
            <span class="ix-card-n">01</span>
            <h2 class="ix-card-h">Master Class</h2>
            <span class="ix-card-arr" aria-hidden="true">↗</span>
          </div>
          <p class="ix-card-desc">
            Guided 12-module walkthrough from first <code>claude</code> session to headless CI/CD. TL;DR-first per module. About 60 minutes end-to-end. <b>Start here if you're new.</b>
          </p>
          <div class="ix-card-meta">
            <span>12 modules</span><span>·</span><span>EN · PT · ES</span><span>·</span><span>printable</span>
          </div>
        </a>

        <a href={`${base}/masterclass/goal-command/`} class="ix-card ix-card-cyan">
          <div class="ix-card-head">
            <span class="ix-card-n">02</span>
            <h2 class="ix-card-h">/goal Class</h2>
            <span class="ix-card-arr" aria-hidden="true">↗</span>
          </div>
          <p class="ix-card-desc">
            Deep dive on the <code>/goal</code> command — worker vs evaluator architecture, anatomy of a good condition, anti-patterns. <b>Read before running unattended agents.</b>
          </p>
          <div class="ix-card-meta">
            <span>8 modules</span><span>·</span><span>~25 min</span><span>·</span><span>printable</span>
          </div>
        </a>

        <a href={`${base}/cookbook/hooks/`} class="ix-card ix-card-yellow">
          <div class="ix-card-head">
            <span class="ix-card-n">03</span>
            <h2 class="ix-card-h">Hook Cookbook</h2>
            <span class="ix-card-arr" aria-hidden="true">↗</span>
          </div>
          <p class="ix-card-desc">
            10 production-ready hook recipes covering all 7 lifecycle event families. Each one: <i>When · Payload · Script · Wire-up · Gotcha</i>. <b>Copy, paste, customize.</b>
          </p>
          <div class="ix-card-meta">
            <span>10 recipes</span><span>·</span><span>7 families</span><span>·</span><span>printable</span>
          </div>
        </a>

        <a href={`${base}/masterclass/routing/`} class="ix-card ix-card-violet">
          <div class="ix-card-head">
            <span class="ix-card-n">04</span>
            <h2 class="ix-card-h">Routing Class</h2>
            <span class="ix-card-arr" aria-hidden="true">↗</span>
          </div>
          <p class="ix-card-desc">
            Extend Claude Code with <b>CCRouter</b> — the local proxy that routes requests to any model by task type. 4 modules of theory + 8 copy-paste routing configs (cost split, failover, long-context, Ollama).
          </p>
          <div class="ix-card-meta">
            <span>4 mods + 8 recipes</span><span>·</span><span>~25 min</span><span>·</span><span>printable</span>
          </div>
        </a>

      </section>

      <section class="ix-about">
        <h2 class="ix-about-h">What this is</h2>
        <p>
          Four standalone resources, designed to compose. The cheatsheet is the dense reference — always one Ctrl+F away. The Master Class is the linear path for newcomers. The /goal Class and Hook Cookbook are depth drops on specific surfaces. Every page has a <code>Resources ▾</code> dropdown so you can jump between them at any time.
        </p>
        <p>
          Everything is static HTML. No tracking, no analytics, no JS framework. Built with Astro, hosted on GitHub Pages. Source on <a href={REPO_URL} target="_blank" rel="noopener">github/cfpperche/claude-core</a>. MIT license — fork it, adapt it, ship your own.
        </p>
      </section>

      <footer class="ix-foot">
        <p class="ix-foot-meta">
          Built against Claude Code <code>v{CC_VERSION}</code>. CLI flags and hook event names track that version. Last revision: 2026-05-17.
        </p>
      </footer>

    </main>

    <style is:global>
      :root[data-theme="poster"] {
        --p-bg: #0a0e1f;
        --p-bg-2: #0e1530;
        --p-ink: #e5e7eb;
        --p-ink-dim: #9ca3af;
        --p-ink-faint: #6b7280;
        --p-green: #39ff14;
        --p-orange: #ff9933;
        --p-red: #ff4d4d;
        --p-cyan: #00e5ff;
        --p-magenta: #ff44ff;
        --p-violet: #a78bfa;
        --p-yellow: #ffe066;
        --font-mono: "JetBrains Mono Variable", ui-monospace, "SF Mono", Menlo, Consolas, monospace;
        --font-sans: "Inter Variable", ui-sans-serif, system-ui, sans-serif;
      }
      html, body { background: var(--p-bg); color: var(--p-ink); overflow-x: clip; }
      .ix-body {
        font-family: var(--font-sans);
        margin: 0;
        background: radial-gradient(ellipse at top, var(--p-bg-2), var(--p-bg) 70%);
        min-height: 100vh;
        padding: 32px 24px 60px;
        overflow-x: clip;
        overflow-wrap: anywhere;
        max-width: 100%;
      }

      .ix-top {
        max-width: 1100px;
        margin: 0 auto 24px;
        display: flex;
        justify-content: flex-end;
        font-family: var(--font-mono);
        font-size: 11px;
      }

      .ix-page { max-width: 1100px; margin: 0 auto; }

      .ix-banner { text-align: center; margin-bottom: 36px; }
      .ix-strip {
        font-family: var(--font-mono);
        font-size: 11px;
        color: var(--p-orange);
        letter-spacing: 0.12em;
        margin-bottom: 14px;
        display: flex;
        justify-content: center;
        gap: 18px;
        flex-wrap: wrap;
      }
      .ix-tag { white-space: nowrap; }
      .ix-title {
        font-family: var(--font-mono);
        font-size: 52px;
        font-weight: 800;
        letter-spacing: -0.02em;
        margin: 8px 0 16px;
        line-height: 1;
      }
      .ix-title-line { display: block; color: var(--p-ink); }
      .ix-title-accent { color: var(--p-green); }
      .ix-sub {
        color: var(--p-ink-dim);
        font-size: 15px;
        margin: 0 auto;
        max-width: 700px;
        line-height: 1.55;
      }
      @media (max-width: 720px) {
        .ix-title { font-size: 32px; }
        .ix-strip { font-size: 9.5px; gap: 10px; }
      }

      .ix-grid {
        display: grid;
        grid-template-columns: 1fr 1fr;
        gap: 16px;
        margin-bottom: 40px;
      }
      @media (max-width: 720px) {
        .ix-grid { grid-template-columns: 1fr; }
      }
      .ix-card {
        display: block;
        background: rgba(0, 0, 0, 0.35);
        border: 1px solid rgba(255, 255, 255, 0.08);
        border-left: 4px solid var(--ix-c, var(--p-cyan));
        border-radius: 3px;
        padding: 22px 24px;
        text-decoration: none;
        color: inherit;
        transition: transform 0.14s, border-color 0.14s, background 0.14s;
      }
      .ix-card:hover {
        transform: translateY(-3px);
        background: rgba(0, 0, 0, 0.5);
        border-color: var(--ix-c, var(--p-cyan));
      }
      .ix-card-green   { --ix-c: var(--p-green); }
      .ix-card-magenta { --ix-c: var(--p-magenta); }
      .ix-card-cyan    { --ix-c: var(--p-cyan); }
      .ix-card-yellow  { --ix-c: var(--p-yellow); }
      .ix-card-violet  { --ix-c: var(--p-violet); }

      .ix-card-head {
        display: flex;
        align-items: baseline;
        gap: 12px;
        margin-bottom: 12px;
      }
      .ix-card-n {
        font-family: var(--font-mono);
        font-size: 14px;
        font-weight: 800;
        color: var(--ix-c, var(--p-cyan));
        letter-spacing: 0.04em;
      }
      .ix-card-h {
        font-family: var(--font-mono);
        font-size: 22px;
        font-weight: 700;
        color: var(--p-ink);
        margin: 0;
        flex: 1;
        letter-spacing: -0.01em;
      }
      .ix-card-arr {
        font-family: var(--font-mono);
        font-size: 16px;
        color: var(--ix-c, var(--p-cyan));
      }
      .ix-card-desc {
        font-size: 14px;
        line-height: 1.55;
        color: var(--p-ink);
        margin: 0 0 12px;
      }
      .ix-card-desc code {
        color: var(--p-orange);
        font-family: var(--font-mono);
        font-size: 12.5px;
      }
      .ix-card-desc b { color: var(--ix-c, var(--p-cyan)); }
      .ix-card-meta {
        display: flex;
        gap: 6px;
        font-family: var(--font-mono);
        font-size: 11px;
        color: var(--p-ink-faint);
        letter-spacing: 0.04em;
        flex-wrap: wrap;
      }

      .ix-about {
        background: rgba(0, 0, 0, 0.3);
        border-left: 3px solid var(--p-cyan);
        border-radius: 2px;
        padding: 18px 22px;
        margin-bottom: 30px;
        font-size: 14px;
        line-height: 1.6;
      }
      .ix-about-h {
        font-family: var(--font-mono);
        font-size: 12px;
        color: var(--p-cyan);
        letter-spacing: 0.06em;
        text-transform: uppercase;
        margin: 0 0 10px;
      }
      .ix-about p { margin: 0 0 12px; color: var(--p-ink); }
      .ix-about p:last-child { margin-bottom: 0; }
      .ix-about code {
        color: var(--p-orange);
        font-family: var(--font-mono);
        font-size: 12.5px;
      }
      .ix-about a {
        color: var(--p-cyan);
        text-decoration: none;
        border-bottom: 1px dashed transparent;
      }
      .ix-about a:hover { border-bottom-color: var(--p-cyan); }

      .ix-foot {
        text-align: center;
        margin-top: 30px;
        padding-top: 20px;
        border-top: 1px solid rgba(255, 255, 255, 0.06);
      }
      .ix-foot-meta {
        font-family: var(--font-mono);
        font-size: 11.5px;
        color: var(--p-ink-faint);
        margin: 0;
      }
      .ix-foot-meta code { color: var(--p-orange); }
    </style>
  </body>
</html>
